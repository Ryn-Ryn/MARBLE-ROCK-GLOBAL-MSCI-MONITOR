// EXPECTED RETURNS ENGINE
// ══════════════════════════════════════════════════════════

// Universe mean/std (used for z-score → reversion target)
const UNIV_MEAN_PE = 16.24, UNIV_STD_PE = 7.62;

function calcExpectedReturns() {
  const horizon  = +document.getElementById('mr-horizon').value;
  const halfLife = +document.getElementById('mr-hl').value;
  const eyGrowth = +document.getElementById('ey-growth').value / 100;
  const combMRW  = +document.getElementById('comb-mrw').value;
  const combEYW  = 1 - combMRW;

  // λ = ln(2)/halfLife — mean reversion speed
  const lambda = Math.log(2) / halfLife;

  return COUNTRIES.filter(c=>c.pe&&c.pe<100&&c.classification!=='Aggregate').map(c=>{
    const pe = c.pe;
    const fwdPE = c.best_pe && c.best_pe>0 && c.best_pe<100 ? c.best_pe : pe;
    const peZ = c.pe_z || 0;

    // MODEL 1: Mean-reversion
    // z-score decays: z_T = z_0 * e^(-λ*T)
    // Implied PE at horizon: PE_T = UNIV_MEAN_PE + z_T * UNIV_STD_PE
    const zT = peZ * Math.exp(-lambda * horizon);
    const peT = Math.max(5, UNIV_MEAN_PE + zT * UNIV_STD_PE);
    // Return = (PE_0/PE_T - 1) multiple spread + earnings yield compounded
    // Simple form: ann_ret = (PE_T/PE_0)^(1/T) - 1 + earnings_yield
    const ey0 = 1/pe;
    const mr_ret = Math.pow(pe/peT, 1/horizon) - 1 + ey0;

    // MODEL 2: Earnings Yield
    // Gordon Growth: E/P + g  (using forward E/P if available)
    const fwd_ey = 1/fwdPE;
    const ey_ret = fwd_ey + eyGrowth;

    // MODEL 3: Combined
    const comb_ret = combMRW * mr_ret + combEYW * ey_ret;

    return {
      bloomberg: c.bloomberg,
      name: c.name,
      cls: c.classification,
      region: c.region,
      pe,
      pe_z: c.pe_z,
      pb: c.pb,
      mr:   Math.round(mr_ret   * 1000) / 10,   // as %
      ey:   Math.round(ey_ret   * 1000) / 10,
      comb: Math.round(comb_ret * 1000) / 10,
    };
  });
}

