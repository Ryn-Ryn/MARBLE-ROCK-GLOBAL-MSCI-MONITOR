    let imgW = availW, imgH = availW / aspect;
    if (imgH > availH) { imgH = availH; imgW = availH * aspect; }
    const imgX = margin + (availW - imgW) / 2;
    pdf.addImage(imgData, 'PNG', imgX, imgY, imgW, imgH, '', 'FAST');

    // Footer
    pdf.setDrawColor(200, 191, 175);
    pdf.setLineWidth(0.3);
    pdf.line(margin, pageH - 8, pageW - margin, pageH - 8);
    pdf.setTextColor(122, 110, 96);
    pdf.setFont('helvetica', 'normal');
    pdf.setFontSize(7);
    pdf.text('Bloomberg-sourced data. For informational purposes only.', margin, pageH - 4);
    pdf.text(`Exported ${new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'})}`, pageW - margin, pageH - 4, { align: 'right' });

    const safeName = title.replace(/[^a-z0-9]+/gi, '_').replace(/^_+|_+$/g, '').slice(0, 60);
    pdf.save(`MSCI_${safeName}.pdf`);

  } catch(err) {
    console.error('PDF export failed:', err);
    alert('PDF export failed: ' + err.message);
  } finally {
    btn.innerHTML = origHTML;
    btn.disabled  = false;
  }
}

