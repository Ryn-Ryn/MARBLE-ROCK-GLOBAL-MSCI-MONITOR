  const pbZMax=pbZVals.length?Math.max(...pbZVals).toFixed(2):'–';
  const signal=z=>z==null?'–':z<-2?'Deeply cheap':z<-1?'Cheap':z<-0.5?'Mildly cheap':z<0.5?'Neutral':z<1?'Mildly exp.':z<2?'Expensive':'Deeply exp.';

  bar.innerHTML=[
    mkStat('Country',country?flag(country.name)+' '+country.name:zTicker,country?.classification||'','var(--text)'),
    mkStat('PE Ratio',peLast.v!=null?peLast.v.toFixed(1)+'x':'–',`mean ${peLast.m!=null?peLast.m.toFixed(1)+'x':'–'}`,'var(--text)'),
    mkStat('PE Z-Score',peLast.z!=null?(peLast.z>=0?'+':'')+peLast.z.toFixed(2)+'σ':'–',pePct!=null?pePct+'th percentile · '+signal(peLast.z):'–',peLast.z!=null?zColor(peLast.z):'var(--text3)'),
    mkStat('PE Z Range',`${peZMin}σ → ${peZMax}σ`,`${zWindow||'Full'}-week lookback`,'var(--text3)'),
    mkStat('P/B Ratio',pbLast&&pbLast.v!=null?pbLast.v.toFixed(2)+'x':'–',pbLast&&pbLast.m!=null?`mean ${pbLast.m.toFixed(2)}x`:'–','var(--text)'),
    mkStat('P/B Z-Score',pbLast&&pbLast.z!=null?(pbLast.z>=0?'+':'')+pbLast.z.toFixed(2)+'σ':'–',pbPct!=null?pbPct+'th percentile · '+signal(pbLast?.z):'–',pbLast&&pbLast.z!=null?zColor(pbLast.z):'var(--text3)'),
    mkStat('P/B Z Range',`${pbZMin}σ → ${pbZMax}σ`,`${zWindow||'Full'}-week lookback`,'var(--text3)'),
    zLogMode ? mkStat('Z Method','Log Z','log(x) normalised · spike-robust','var(--purple2)') : mkStat('Z Method','Linear','standard z-score','var(--text3)'),
    (()=>{const px=PRICE_DATA[zTicker];if(!px||!px.length)return '';const lat=px[px.length-1];const prv=px[px.length-2];const chg=prv?((lat[1]-prv[1])/prv[1]*100):null;const col=chg>=0?'var(--green2)':'var(--red2)';const fmtPx=lat[1]>=10000?lat[1].toLocaleString(undefined,{maximumFractionDigits:0}):lat[1].toFixed(2);return mkStat('Index Level',fmtPx,chg!=null?(chg>=0?'+':'')+chg.toFixed(2)+'% WoW':lat[0],col);})(),
  ].filter(Boolean).join('');
}


// ── Z-Tab Price Chart ─────────────────────────────────
let _zPxSig = 2;
let _zPxHover = null;
let _zPxHoverDate = null; // shared date for crosshair sync

function setZPxSig(level, btn) {
  _zPxSig = level;
  document.querySelectorAll('[data-zpxsig]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  drawZPxChart();
}

function drawZPxChart() {
  const wrap = document.getElementById('z-px-wrap');
  const cv   = document.getElementById('z-px-chart');
  const ro   = document.getElementById('z-px-readout');
  if (!wrap || !cv) return;

  const W = wrap.clientWidth || 700;
  const H = wrap.clientHeight || 200;
  cv.width = W; cv.height = H;
  cv.style.width = W+'px'; cv.style.height = H+'px';
  const ctx = cv.getContext('2d');
  ctx.clearRect(0, 0, W, H);

  const pxAll = PRICE_DATA[zTicker];
  if (!pxAll || !pxAll.length) {
    ctx.fillStyle = 'rgba(148,163,184,.5)';
    ctx.font = '12px Inter,sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('No price data', W/2, H/2);
    return;
  }

  // Filter by view range
  const now = new Date('2026-03-06');
  let cutoffDate;
  if (zRange && zRange.startsWith('Y:')) {
    cutoffDate = new Date(parseInt(zRange.slice(2)), 0, 1);
  } else {
    const days = {['1Y']:365.25,['2Y']:2*365.25,['5Y']:5*365.25,['10Y']:10*365.25,['All']:99999}[zRange]||99999;
    cutoffDate = new Date(now.getTime() - days*86400000);
  }
  const cutStr = cutoffDate.toISOString().slice(0,10);
  let pxData = pxAll.filter(r => r[0] >= cutStr);
  // Apply zoom when active
  if (_zZoomStart && _zZoomEnd) {
    pxData = pxData.filter(r => r[0] >= _zZoomStart && r[0] <= _zZoomEnd);
  }
  if (!pxData.length) return;

  // Build z-map from pre-computed _zData + _zDataPb
  const zMap = {};
  if (_zData && _zData.length) _zData.forEach(r => { if (r.z != null) zMap[r.d] = r.z; });
  if (_zDataPb && _zDataPb.length) _zDataPb.forEach(r => {
    if (r.z != null) zMap[r.d] = zMap[r.d] != null ? (zMap[r.d]+r.z)/2 : r.z;
  });

  const PAD = {l:58, r:14, t:12, b:28};
  const cw = W - PAD.l - PAD.r;
  const ch = H - PAD.t - PAD.b;

  // Log scale on absolute prices; time-proportional x-axis
  const pxTimes = pxData.map(r => new Date(r[0]).getTime());
  const t0 = pxTimes[0], t1 = pxTimes[pxTimes.length-1] || pxTimes[0]+1;
  const tRange = t1 - t0 || 1;
  const prices = pxData.map(r => r[1]);
  const logMin = Math.log(Math.min(...prices));
  const logMax = Math.log(Math.max(...prices));
  const logRange = logMax - logMin || 1;

  function xOf(i) { return PAD.l + (pxTimes[i] - t0) / tRange * cw; }
  function yOf(px) { return PAD.t + ch - ((Math.log(px) - logMin) / logRange) * ch; }

  const cs = getComputedStyle(document.documentElement);
  const colBg   = cs.getPropertyValue('--card').trim() || '#faf8f4';
  const colLine = cs.getPropertyValue('--accent').trim() || '#2a4a7f';
  const colText = cs.getPropertyValue('--text3').trim() || '#7a6e60';
  const colGrid = 'rgba(100,116,139,0.12)';

  ctx.fillStyle = colBg;
  ctx.fillRect(0, 0, W, H);

  // Signal bands
  let regStart = null, regType = null;
  function flushReg(ex) {
    if (regStart == null) return;
    ctx.fillStyle = regType === 'over' ? 'rgba(239,68,68,0.15)' : 'rgba(34,197,94,0.15)';
    ctx.fillRect(regStart, PAD.t, ex - regStart, ch);
    regStart = null; regType = null;
  }
  for (let i = 0; i < pxData.length; i++) {
    const z = zMap[pxData[i][0]], x = xOf(i);
    const type = z != null ? (z > _zPxSig ? 'over' : z < -_zPxSig ? 'under' : null) : null;
    if (type !== regType) { flushReg(x); if (type) { regStart = x; regType = type; } }
  }
  flushReg(xOf(pxData.length - 1));

  // Horizontal grid + Y labels (log scale, nice round values)
  ctx.strokeStyle = colGrid; ctx.lineWidth = 1; ctx.setLineDash([3, 4]);
  const rawMin = Math.min(...prices), rawMax = Math.max(...prices);
  const mag0 = Math.pow(10, Math.floor(Math.log10(rawMin)));
  const yTicks = [];
  for (let base = mag0; base <= rawMax * 1.1; base *= 10) {
    for (const mul of [1, 2, 5]) {
      const v = base * mul;
      if (v >= rawMin * 0.9 && v <= rawMax * 1.1) yTicks.push(v);
    }
  }
  ctx.fillStyle = colText; ctx.font = '9px Inter,sans-serif'; ctx.textAlign = 'right';
  yTicks.forEach(v => {
    const py = yOf(v);
    if (py < PAD.t - 4 || py > PAD.t + ch + 4) return;
    ctx.beginPath(); ctx.moveTo(PAD.l, py); ctx.lineTo(W - PAD.r, py); ctx.stroke();
    const lbl = v >= 1e6 ? (v/1e6).toFixed(v>=1e7?0:1)+'M'
              : v >= 1e3 ? (v/1e3).toFixed(v>=1e4?0:1)+'k'
              : v.toFixed(0);
    ctx.fillText(lbl, PAD.l - 4, py + 3);
  });

  // Vertical year grid lines + X labels
  const totalYrs = tRange / (365.25 * 86400000);
  const tickYrs = totalYrs <= 2 ? 0.25 : totalYrs <= 10 ? 1 : totalYrs <= 20 ? 2 : totalYrs <= 50 ? 5 : 10;
  const startYr = new Date(t0).getUTCFullYear(), endYr = new Date(t1).getUTCFullYear() + 1;
  ctx.strokeStyle = 'rgba(100,116,139,0.10)'; ctx.lineWidth = 0.8;
  ctx.fillStyle = colText; ctx.font = '9px Inter,sans-serif'; ctx.textAlign = 'center';
  for (let yr = Math.ceil(startYr / tickYrs) * tickYrs; yr <= endYr; yr += tickYrs) {
    const tickT = new Date(yr, 0, 1).getTime();
    if (tickT < t0 || tickT > t1) continue;
    const tx = PAD.l + (tickT - t0) / tRange * cw;
    ctx.beginPath(); ctx.moveTo(tx, PAD.t); ctx.lineTo(tx, PAD.t+ch); ctx.stroke();
    ctx.fillText(yr, tx, H - PAD.b + 12);
  }
  ctx.setLineDash([]);

  // Price line
  ctx.beginPath(); ctx.strokeStyle = colLine; ctx.lineWidth = 1.8;
  pxData.forEach((r, i) => {
    const x = xOf(i), y = yOf(r[1]);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.stroke();

  // Hover crosshair
  if (_zPxHover != null && _zPxHover >= 0 && _zPxHover < pxData.length) {
    const i = _zPxHover;
    const x = xOf(i), y = yOf(pxData[i][1]);
    ctx.strokeStyle = 'rgba(122,110,96,0.4)'; ctx.lineWidth = 1; ctx.setLineDash([3,3]);
    ctx.beginPath(); ctx.moveTo(x, PAD.t); ctx.lineTo(x, PAD.t+ch); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = colLine; ctx.beginPath(); ctx.arc(x, y, 4, 0, Math.PI*2); ctx.fill();
    const d = pxData[i][0], px = pxData[i][1], z = zMap[d];
    const fmtPx = px >= 10000 ? px.toLocaleString(undefined,{maximumFractionDigits:0}) : px.toFixed(2);
    const zStr = z != null ? ` | Z: ${z.toFixed(2)}` : '';
    const sig  = z != null ? (z > _zPxSig ? ' 🔴 Overvalued' : z < -_zPxSig ? ' 🟢 Undervalued' : '') : '';
    if (ro) ro.innerHTML = `<span>${d}</span><span style="color:var(--accent);margin-left:8px;">${fmtPx}</span><span style="color:var(--text2);">${zStr}</span><span style="margin-left:6px;">${sig}</span>`;
  }

  // Drag-to-zoom + hover — use cv._drag object so state persists across redraws
  if (!cv._drag) cv._drag = { start: null, curr: null, active: false };
  const drag = cv._drag;

  function _zPxGetTime(mx) { return t0 + (mx - PAD.l) / cw * tRange; }
  function _zPxNearestIdx(mx) {
    const tHit = _zPxGetTime(mx);
    let best = 0, bestD = Infinity;
    for (let ii = 0; ii < pxData.length; ii++) {
      const d = Math.abs(pxTimes[ii] - tHit);
      if (d < bestD) { bestD = d; best = ii; } else if (d > bestD) break;
    }
    return best;
  }

  // Draw drag-selection overlay on top of already-rendered chart
  function _drawZSel() {
    if (!drag.active || drag.start === null || drag.curr === null) return;
    const sx = PAD.l + (drag.start - t0) / tRange * cw;
    const ex = PAD.l + (drag.curr  - t0) / tRange * cw;
    const x1 = Math.min(sx, ex), x2 = Math.max(sx, ex);
    ctx.fillStyle = 'rgba(59,130,246,0.15)';
    ctx.fillRect(x1, PAD.t, x2 - x1, ch);
    ctx.strokeStyle = 'rgba(59,130,246,0.8)';
    ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(x1, PAD.t); ctx.lineTo(x1, PAD.t+ch); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x2, PAD.t); ctx.lineTo(x2, PAD.t+ch); ctx.stroke();
    const d1s = new Date(Math.min(drag.start, drag.curr)).toISOString().slice(0,7);
    const d2s = new Date(Math.max(drag.start, drag.curr)).toISOString().slice(0,7);
    ctx.fillStyle = '#3b82f6'; ctx.font = 'bold 10px Inter,sans-serif'; ctx.textAlign = 'center';
    const lw = ctx.measureText(d1s + ' → ' + d2s).width + 12;
    const lx = Math.min(Math.max((x1+x2)/2, PAD.l + lw/2), W - PAD.r - lw/2);
    ctx.fillStyle = 'rgba(15,23,42,0.75)';
    ctx.fillRect(lx - lw/2, PAD.t + ch + 3, lw, 14);
    ctx.fillStyle = '#93c5fd';
    ctx.fillText(d1s + ' → ' + d2s, lx, PAD.t + ch + 13);
  }

  cv.onmousedown = e => {
    if (e.button !== 0) return;
    const rect = cv.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    if (mx < PAD.l || mx > PAD.l + cw) return;
    drag.start = _zPxGetTime(mx); drag.curr = drag.start; drag.active = false;
    e.preventDefault();
  };

  cv.onmousemove = e => {
    const rect = cv.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    if (drag.start !== null) {
      drag.curr = _zPxGetTime(mx);
      drag.active = Math.abs(drag.curr - drag.start) > tRange * 0.005;
      drawZPxChart(); // redraws chart + calls _drawZSel below
      if (drag.active) return;
    }
    if (mx >= PAD.l && mx <= PAD.l + cw) {
      _zPxHover = _zPxNearestIdx(mx);
      _zPxHoverDate = pxData[_zPxHover]?.[0] || null;
    } else { _zPxHover = null; _zPxHoverDate = null; }
    if (!drag.active) drawZPxChart();
  };

  cv.onmouseup = e => {
    if (drag.start === null) return;
    const tStart = drag.start, tCurr = drag.curr, wasActive = drag.active;
    drag.start = null; drag.curr = null; drag.active = false;
    if (wasActive) {
      const d1 = new Date(Math.min(tStart, tCurr)).toISOString().slice(0,10);
      const d2 = new Date(Math.max(tStart, tCurr)).toISOString().slice(0,10);
      _applyZZoom(d1, d2);
    }
  };

  cv.onmouseleave = () => {
    drag.start = null; drag.curr = null; drag.active = false;
    _zPxHover = null; _zPxHoverDate = null;
    drawZPxChart();
  };

  cv.style.cursor = 'crosshair';
  // Draw selection overlay AFTER all other chart drawing
