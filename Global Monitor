function flag(name) {
  const iso = ISO_MAP[name]; if (!iso) return '🌐';
  return [...iso.toUpperCase()].map(c => String.fromCodePoint(127397 + c.charCodeAt(0))).join('');
}
function fmt(v, d=2) { return (v==null||v===undefined)?'–':v.toFixed(d); }
function fmtX(v,d=1){ return v==null?'–':v.toFixed(d)+'x'; }
function fmtP(v,d=1){ return v==null?'–':v.toFixed(d)+'%'; }

function zLabel(z) {
  if (z==null) return '–';
  return (z>=0?'+':'')+z.toFixed(2)+'σ';
}
function zColor(z) {
  if (z==null) return 'var(--text3)';
  if (z > 2)   return '#ef4444';
  if (z > 1)   return '#f97316';
  if (z > 0.5) return '#eab308';
  if (z < -2)  return '#10b981';
  if (z < -1)  return '#34d399';
  if (z < -0.5) return '#6ee7b7';
  return 'var(--text3)';
}
function clsColor(cls) {
  const m = {Developed:'var(--dev)',Emerging:'var(--em)',Frontier:'var(--fr)',Aggregate:'var(--agg)'};
