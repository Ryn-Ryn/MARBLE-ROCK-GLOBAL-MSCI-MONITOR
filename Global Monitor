  const country=COUNTRIES.find(c=>c.bloomberg===zTicker);
  const mkStat=(lbl,val,sub,color)=>`<div class="z-stat-cell"><div class="z-stat-lbl">${lbl}</div><div class="z-stat-val" style="${color?'color:'+color:''}">${val}</div><div class="z-stat-sub">${sub}</div></div>`;

  if(!peData||!peData.length){
    bar.innerHTML=mkStat('Status','No Data','no weekly history','var(--text3)'); return;
  }

  const peLast=peData[peData.length-1];
  const pbLast=pbData&&pbData.length?pbData[pbData.length-1]:null;
  const pePct=zPercentile(peData);
  const pbPct=pbData?zPercentile(pbData):null;
  const peZVals=peData.map(d=>d.z).filter(v=>v!=null);
  const pbZVals=pbData?pbData.map(d=>d.z).filter(v=>v!=null):[];
  const peZMin=peZVals.length?Math.min(...peZVals).toFixed(2):'–';
