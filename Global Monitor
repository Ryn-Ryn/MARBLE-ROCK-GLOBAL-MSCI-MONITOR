  const W = wrap.clientWidth || 700;
  const H = wrap.clientHeight || 260;
  cv.width = W; cv.height = H;
  cv.style.width = W+'px'; cv.style.height = H+'px';
  const ctx = cv.getContext('2d');
  ctx.clearRect(0, 0, W, H);

  const pxData = _pdGetPxData();
  if (!pxData.length) {
    ctx.fillStyle = 'rgba(148,163,184,.5)';
    ctx.font = '12px Inter,sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('No price data available', W/2, H/2);
    return;
  }

  // Build combined Z map (PE + P/B average)
  const peZ = _pdGetZ('pe'), pbZ = _pdGetZ('pb');
  const zMap = {};
  const peMap = {}; peZ.forEach(r => { if (r.z != null) peMap[r.d] = r.z; });
  const pbMap = {}; pbZ.forEach(r => { if (r.z != null) pbMap[r.d] = r.z; });
  new Set([...Object.keys(peMap), ...Object.keys(pbMap)]).forEach(d => {
    const pez = peMap[d], pbz = pbMap[d];
    zMap[d] = (pez != null && pbz != null) ? (pez+pbz)/2 : pez ?? pbz;
  });

  const PAD = {l:58, r:14, t:12, b:28};
  const cw = W - PAD.l - PAD.r;
  const ch = H - PAD.t - PAD.b;

  // Log scale on absolute prices; time-proportional x-axis
  const pxTimes = pxData.map(r => new Date(r[0]).getTime());
  const t0 = pxTimes[0], t1 = pxTimes[pxTimes.length-1] || pxTimes[0]+1;
  const tRange = t1 - t0 || 1;
  const prices = pxData.map(r => r[1]);
  const logMin = Math.log(Math.min(...prices));
  const logMax = Math.log(Math.max(...prices));
  const logRange = logMax - logMin || 1;

  function xOf(i) { return PAD.l + (pxTimes[i] - t0) / tRange * cw; }
  function yOf(px) { return PAD.t + ch - ((Math.log(px) - logMin) / logRange) * ch; }

  const cs = getComputedStyle(document.documentElement);
  const colBg   = cs.getPropertyValue('--bg2').trim() || '#1e293b';
  const colLine = cs.getPropertyValue('--acc').trim() || '#38bdf8';
  const colText = cs.getPropertyValue('--text3').trim() || '#94a3b8';
  const colGrid = 'rgba(100,116,139,0.15)';

  ctx.fillStyle = colBg;
  ctx.fillRect(0, 0, W, H);

  // Signal bands
  const sigThresh = _pdPxSigLevel;
  let regionStart = null, regionType = null;
  function flushRegion(endX) {
    if (regionStart === null) return;
    ctx.fillStyle = regionType === 'over' ? 'rgba(239,68,68,0.18)' : 'rgba(34,197,94,0.18)';
    ctx.fillRect(regionStart, PAD.t, endX - regionStart, ch);
    ctx.strokeStyle = regionType === 'over' ? 'rgba(239,68,68,0.5)' : 'rgba(34,197,94,0.5)';
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(regionStart, PAD.t); ctx.lineTo(regionStart, PAD.t+ch);
    ctx.moveTo(endX, PAD.t);       ctx.lineTo(endX, PAD.t+ch);
    ctx.stroke();
    regionStart = null; regionType = null;
  }
  for (let i = 0; i < pxData.length; i++) {
    const z = zMap[pxData[i][0]], x = xOf(i);
    if (z == null) { flushRegion(x); continue; }
    const type = z > sigThresh ? 'over' : z < -sigThresh ? 'under' : null;
    if (type !== regionType) { flushRegion(x); if (type) { regionStart = x; regionType = type; } }
  }
  flushRegion(xOf(pxData.length - 1));

  // Horizontal grid + Y labels (log scale, nice round values)
  ctx.strokeStyle = colGrid; ctx.lineWidth = 1; ctx.setLineDash([3, 4]);
  const totalYrs = tRange / (365.25 * 86400000);
  // Pick nice log-scale Y ticks
  const rawMin = Math.min(...prices), rawMax = Math.max(...prices);
  const mag0 = Math.pow(10, Math.floor(Math.log10(rawMin)));
  const yTicks = [];
  for (let base = mag0; base <= rawMax * 1.1; base *= 10) {
    for (const mul of [1, 2, 5]) {
      const v = base * mul;
      if (v >= rawMin * 0.9 && v <= rawMax * 1.1) yTicks.push(v);
    }
  }
  ctx.fillStyle = colText; ctx.font = '9px Inter,sans-serif'; ctx.textAlign = 'right';
  yTicks.forEach(v => {
    const py = yOf(v);
    if (py < PAD.t - 4 || py > PAD.t + ch + 4) return;
    ctx.beginPath(); ctx.moveTo(PAD.l, py); ctx.lineTo(W - PAD.r, py); ctx.stroke();
    const lbl = v >= 1e6 ? (v/1e6).toFixed(v>=1e7?0:1)+'M'
              : v >= 1e3 ? (v/1e3).toFixed(v>=1e4?0:1)+'k'
              : v.toFixed(0);
    ctx.fillText(lbl, PAD.l - 4, py + 3);
  });

  // Vertical year grid lines + X labels
  const tickYrs = totalYrs <= 2 ? 0.25 : totalYrs <= 10 ? 1 : totalYrs <= 20 ? 2 : totalYrs <= 50 ? 5 : 10;
  const startYr = new Date(t0).getUTCFullYear();
  const endYr   = new Date(t1).getUTCFullYear() + 1;
  ctx.strokeStyle = 'rgba(100,116,139,0.10)'; ctx.lineWidth = 0.8;
  ctx.fillStyle = colText; ctx.font = '9px Inter,sans-serif'; ctx.textAlign = 'center';
  for (let yr = Math.ceil(startYr / tickYrs) * tickYrs; yr <= endYr; yr += tickYrs) {
    const tickT = new Date(yr, 0, 1).getTime();
    if (tickT < t0 || tickT > t1) continue;
    const tx = PAD.l + (tickT - t0) / tRange * cw;
    ctx.beginPath(); ctx.moveTo(tx, PAD.t); ctx.lineTo(tx, PAD.t + ch); ctx.stroke();
    ctx.fillText(yr, tx, H - PAD.b + 12);
  }
  ctx.setLineDash([]);

  // Price line
  ctx.beginPath(); ctx.strokeStyle = colLine; ctx.lineWidth = 1.8;
  for (let i = 0; i < pxData.length; i++) {
    const x = xOf(i), y = yOf(pxData[i][1]);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  }
  ctx.stroke();

  // Hover crosshair
  if (_pdPxHover !== null) {
    const i = _pdPxHover;
    if (i >= 0 && i < pxData.length) {
      const x = xOf(i), y = yOf(pxData[i][1]);
      ctx.strokeStyle = 'rgba(148,163,184,0.5)'; ctx.lineWidth = 1; ctx.setLineDash([3,3]);
      ctx.beginPath(); ctx.moveTo(x, PAD.t); ctx.lineTo(x, PAD.t+ch); ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = colLine; ctx.beginPath(); ctx.arc(x, y, 4, 0, Math.PI*2); ctx.fill();
      const d = pxData[i][0], px = pxData[i][1], z = zMap[d];
      const fmtPx = px >= 10000 ? px.toLocaleString(undefined,{maximumFractionDigits:0}) : px.toFixed(2);
      const zStr  = z != null ? ` | Z: ${z.toFixed(2)}` : '';
      const sigStr = z != null ? (z > sigThresh ? ' 🔴 Overvalued' : z < -sigThresh ? ' 🟢 Undervalued' : '') : '';
      if (ro) ro.innerHTML = `<span>${d}</span><span style="color:${colLine};margin-left:8px;">${fmtPx}</span><span style="color:var(--text2);">${zStr}</span><span style="margin-left:6px;">${sigStr}</span>`;
    }
  }

  // Drag-to-zoom + hover — persistent per-canvas state
  if (!cv._drag) cv._drag = { start: null, curr: null, active: false };
  const drag = cv._drag;

  function _pdPxGetTime(mx) { return t0 + (mx - PAD.l) / cw * tRange; }
  function _pdPxNearestIdx(mx) {
    const tHit = _pdPxGetTime(mx);
    let best = 0, bestD = Infinity;
    for (let ii = 0; ii < pxData.length; ii++) {
      const d = Math.abs(pxTimes[ii] - tHit);
      if (d < bestD) { bestD = d; best = ii; } else if (d > bestD) break;
    }
    return best;
  }

  function _drawPdSel() {
    if (!drag.active || drag.start === null || drag.curr === null) return;
    const sx = PAD.l + (drag.start - t0) / tRange * cw;
    const ex = PAD.l + (drag.curr  - t0) / tRange * cw;
    const x1 = Math.min(sx, ex), x2 = Math.max(sx, ex);
    ctx.fillStyle = 'rgba(59,130,246,0.15)';
    ctx.fillRect(x1, PAD.t, x2 - x1, ch);
    ctx.strokeStyle = 'rgba(59,130,246,0.8)';
    ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(x1, PAD.t); ctx.lineTo(x1, PAD.t+ch); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x2, PAD.t); ctx.lineTo(x2, PAD.t+ch); ctx.stroke();
    const d1s = new Date(Math.min(drag.start, drag.curr)).toISOString().slice(0,7);
    const d2s = new Date(Math.max(drag.start, drag.curr)).toISOString().slice(0,7);
    const label = d1s + ' → ' + d2s;
    ctx.font = 'bold 10px Inter,sans-serif'; ctx.textAlign = 'center';
    const lw = ctx.measureText(label).width + 12;
    const lx = Math.min(Math.max((x1+x2)/2, PAD.l + lw/2), W - PAD.r - lw/2);
    ctx.fillStyle = 'rgba(15,23,42,0.75)';
    ctx.fillRect(lx - lw/2, PAD.t + ch + 3, lw, 14);
    ctx.fillStyle = '#93c5fd';
    ctx.fillText(label, lx, PAD.t + ch + 13);
  }

  cv.onmousedown = e => {
    if (e.button !== 0) return;
    const rect = cv.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    if (mx < PAD.l || mx > PAD.l + cw) return;
    drag.start = _pdPxGetTime(mx); drag.curr = drag.start; drag.active = false;
    e.preventDefault();
  };

  cv.onmousemove = e => {
    const rect = cv.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    if (drag.start !== null) {
      drag.curr = _pdPxGetTime(mx);
      drag.active = Math.abs(drag.curr - drag.start) > tRange * 0.005;
      _pdDrawPx();
      if (drag.active) return;
    }
    if (mx >= PAD.l && mx <= PAD.l + cw) {
      _pdPxHover = _pdPxNearestIdx(mx);
    } else { _pdPxHover = null; }
    if (!drag.active) _pdDrawPx();
  };

  cv.onmouseup = e => {
    if (drag.start === null) return;
    const tStart = drag.start, tCurr = drag.curr, wasActive = drag.active;
    drag.start = null; drag.curr = null; drag.active = false;
    if (wasActive) {
      const d1 = new Date(Math.min(tStart, tCurr)).toISOString().slice(0,10);
      const d2 = new Date(Math.max(tStart, tCurr)).toISOString().slice(0,10);
      _applyPdZoom(d1, d2);
    }
  };

  cv.onmouseleave = () => {
    drag.start = null; drag.curr = null; drag.active = false;
    _pdPxHover = null; _pdDrawPx();
  };

  cv.style.cursor = 'crosshair';
  _drawPdSel();
}

function closeProfileDetail() {
  document.getElementById('profile-detail-view').style.display = 'none';
  document.getElementById('profile-grid-view').style.display = 'block';
}

// ══════════════════════════════════════════════════════════
// PROFILE DETAIL — Z-SCORE & PE SPREAD CHARTS
// ══════════════════════════════════════════════════════════
// State
let _pdTicker  = null;
let _pdWindow  = 52;
let _pdRange   = '5Y';
let _pdZoomStart=null, _pdZoomEnd=null;
let _pdLogMode = true;
let _pdOscMode = 'pe';

// ── helpers ──────────────────────────────────────────────
function _pdCutoff(range) {
  const now = new Date('2026-03-06');
  if (range && range.startsWith('Y:')) return new Date(parseInt(range.slice(2)), 0, 1);
  const days = {'1Y':365,'2Y':730,'5Y':1826,'10Y':3652,'All':99999}[range] || 99999;
  return new Date(now.getTime() - days * 86400000);
}

function _pdGetZ(metric) {
  const raw = HISTORICAL[_pdTicker] || [];
  const fi  = metric === 'pe' ? 2 : 4;
  const vals = raw.map(r => [r[0], r[fi]]).filter(r => r[1] != null && r[1] > 0);
  const W    = _pdWindow || vals.length;
  const cutoff = _pdCutoff(_pdRange);
  const res  = [];
  for (let i = 0; i < vals.length; i++) {
    const wv = vals.slice(Math.max(0, i - W + 1), i + 1).map(r => r[1]);
    if (wv.length < 4) { res.push({d:vals[i][0], v:vals[i][1], z:null, m:null, s:null}); continue; }
    let mean, std, zVal;
    if (_pdLogMode) {
      const lv = wv.map(Math.log), lx = Math.log(vals[i][1]);
      const lm = lv.reduce((a,b)=>a+b) / lv.length;
      const lvar = lv.reduce((a,b)=>a+(b-lm)**2, 0) / (lv.length-1);
      const ls = Math.sqrt(lvar);
      mean = Math.exp(lm + lvar/2);
      std  = mean * Math.sqrt(Math.exp(lvar)-1);
      zVal = ls > 0 ? (lx - lm) / ls : 0;
    } else {
      mean = wv.reduce((a,b)=>a+b) / wv.length;
      std  = Math.sqrt(wv.reduce((a,b)=>a+(b-mean)**2, 0) / (wv.length-1));
      zVal = std > 0 ? (vals[i][1] - mean) / std : 0;
    }
    res.push({d:vals[i][0], v:vals[i][1], z:zVal, m:mean, s:std});
  }
  let pdZRes = res.filter(r => new Date(r.d) >= _pdCutoff(_pdRange));
  if (_pdZoomStart && _pdZoomEnd) {
    pdZRes = pdZRes.filter(r => r.d >= _pdZoomStart && r.d <= _pdZoomEnd);
  }
  return pdZRes;
}

// ── control callbacks ─────────────────────────────────────
function pdSetW(w, btn) {
  _pdWindow = w;
  document.querySelectorAll('[data-pdw]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  _pdDrawPx();  // price chart Z signals depend on window
  _pdDrawZ();
}
function pdSetR(r, btn) {
  _pdRange = r; _pdZoomStart = null; _pdZoomEnd = null;
  document.getElementById('pd-zoom-bar')?.remove();
  document.querySelectorAll('[data-pdr]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const inp = document.getElementById('pd-custom-year'); if (inp) inp.value = '';
  _pdPxRange = r;  // sync price chart range
  _pdDrawPx();
  _pdDrawZ();
}
function pdSetRCustom(val) {
  const yr = parseInt(val);
  if (!val || isNaN(yr) || yr < 1990 || yr > 2025) return;
  _pdRange = 'Y:' + yr;
  _pdPxRange = 'Y:' + yr;
  document.querySelectorAll('[data-pdr]').forEach(b => b.classList.remove('active'));
  _pdDrawPx();
  _pdDrawZ();
}
function pdSetLog(mode, btn) {
  _pdLogMode = mode;
  document.querySelectorAll('[data-pdlog]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  _pdDrawPx();
  _pdDrawZ();
}
function pdSetOsc(mode, btn) {
  _pdOscMode = mode;
  document.querySelectorAll('[data-pdoscm]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  _pdDrawOsc();
}

// ── main draw entry ───────────────────────────────────────
function _pdDrawZ() {
  if (!_pdTicker) return;
  const country = COUNTRIES.find(c => c.bloomberg === _pdTicker);
  const cName   = country ? country.name : _pdTicker;
  const winLbl  = _pdWindow === 0 ? 'Full' : _pdWindow + 'W';
  const logLbl  = _pdLogMode ? ' · Log Z' : '';
  const el = id => document.getElementById(id);

  if (el('pd-title-pe')) el('pd-title-pe').textContent = flag(cName) + ' ' + cName + ' — PE Ratio · Z-Score (' + winLbl + logLbl + ')';
  if (el('pd-title-pb')) el('pd-title-pb').textContent = flag(cName) + ' ' + cName + ' — P/B Ratio · Z-Score (' + winLbl + logLbl + ')';

  if (!HISTORICAL[_pdTicker]) {
    ['pd-z-main','pd-z-pb','pd-z-osc'].forEach(id => {
      const cv = el(id); if (!cv) return;
      const dpr = window.devicePixelRatio||1, W = cv.parentElement.clientWidth||600, H = cv.parentElement.clientHeight||160;
      cv.width = W*dpr; cv.height = H*dpr;
      cv.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;';
      const ctx = cv.getContext('2d');
      ctx.setTransform(dpr,0,0,dpr,0,0); ctx.clearRect(0,0,W,H);
      ctx.fillStyle = 'rgba(122,110,96,.55)'; ctx.font = '13px Inter,sans-serif'; ctx.textAlign = 'center';
      ctx.fillText('No weekly time-series data for this market', W/2, H/2);
    });
    _pdStatsBar(null, null);
    return;
  }

  const peD = _pdGetZ('pe');
  const pbD = _pdGetZ('pb');
  _pdStatsBar(peD, pbD);
  _pdDrawValueCanvas('pd-z-main', peD, 'var(--accent2)', 'pd-z-readout');
  _pdDrawValueCanvas('pd-z-pb',   pbD, 'var(--green2)',  null);
  _pdDrawOsc(peD, pbD);
}

function _pdStatsBar(peD, pbD) {
  const bar = document.getElementById('pd-stats-bar'); if (!bar) return;
  const country = COUNTRIES.find(c => c.bloomberg === _pdTicker);
  const mk = (lbl,val,sub,col) => '<div class="z-stat-cell"><div class="z-stat-lbl">'+lbl+'</div><div class="z-stat-val" style="'+(col?'color:'+col:'')+'">'+val+'</div><div class="z-stat-sub">'+sub+'</div></div>';
  if (!peD || !peD.length) { bar.innerHTML = mk('Status','No Data','no weekly history','var(--text3)'); return; }
  const pL = peD[peD.length-1];
  const bL = pbD && pbD.length ? pbD[pbD.length-1] : null;
  const pct = arr => { const zv = arr.map(d=>d.z).filter(v=>v!=null), l = zv[zv.length-1]; return zv.length>1 ? Math.round(zv.filter(v=>v<=l).length/zv.length*100) : null; };
  const sig = z => z==null?'–':z<-2?'Deeply cheap':z<-1?'Cheap':z<-0.5?'Mildly cheap':z<0.5?'Neutral':z<1?'Mildly exp.':z<2?'Expensive':'Deeply exp.';
  const pePct = pct(peD);
  bar.innerHTML = [
    mk('PE Ratio',   pL.v!=null ? pL.v.toFixed(1)+'x' : '–', pL.m!=null ? 'mean '+pL.m.toFixed(1)+'x' : '–', 'var(--text)'),
    mk('PE Z-Score', pL.z!=null ? (pL.z>=0?'+':'')+pL.z.toFixed(2)+'σ' : '–', pePct!=null ? pePct+'th pct · '+sig(pL.z) : '–', pL.z!=null ? zColor(pL.z) : 'var(--text3)'),
    mk('P/B Ratio',  bL&&bL.v!=null ? bL.v.toFixed(2)+'x' : '–', bL&&bL.m!=null ? 'mean '+bL.m.toFixed(2)+'x' : '–', 'var(--text)'),
    mk('P/B Z',      bL&&bL.z!=null ? (bL.z>=0?'+':'')+bL.z.toFixed(2)+'σ' : '–', '–', bL&&bL.z!=null ? zColor(bL.z) : 'var(--text3)'),
    mk('Signal',     zLabel(pL.z), country ? country.classification : '', pL.z!=null ? zColor(pL.z) : 'var(--text3)'),
    _pdLogMode ? mk('Z Method','Log Z','log normalised','var(--purple2)') : mk('Z Method','Linear','standard z-score','var(--text3)'),
  ].join('');
}

function _pdDrawValueCanvas(canvasId, data, lineColor, readoutId) {
  const cv = document.getElementById(canvasId); if (!cv) return;
  const dpr = window.devicePixelRatio||1;
  const W = cv.parentElement.clientWidth||700, H = cv.parentElement.clientHeight||320;
  cv.width = Math.round(W*dpr); cv.height = Math.round(H*dpr);
  cv.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;';
  const ctx = cv.getContext('2d');
  ctx.setTransform(dpr,0,0,dpr,0,0); ctx.clearRect(0,0,W,H);

  if (!data || data.length < 2) {
    ctx.fillStyle = 'rgba(122,110,96,.5)'; ctx.font = '12px Inter'; ctx.textAlign = 'center';
    ctx.fillText('Insufficient data', W/2, H/2); return;
  }

  const pad = {t:14, r:18, b:30, l:48};
  const cw = W-pad.l-pad.r, ch = H-pad.t-pad.b;
  const allV = data.flatMap(d => [d.v, d.m!=null&&d.s!=null?d.m+d.s:null, d.m!=null&&d.s!=null?d.m-d.s:null]).filter(v=>v!=null);
  const vMin = Math.min(...allV)*0.985, vMax = Math.max(...allV)*1.015;
  const xOf = i => pad.l + (i/(data.length-1))*cw;
  const yOf = v => pad.t + ch*(1-(v-vMin)/(vMax-vMin));

  // 1σ band
  ctx.beginPath();
  data.forEach((d,i) => { if(d.m==null||d.s==null) return; i===0 ? ctx.moveTo(xOf(i),yOf(d.m+d.s)) : ctx.lineTo(xOf(i),yOf(d.m+d.s)); });
  [...data].reverse().forEach((d,i,a) => { if(d.m==null||d.s==null) return; ctx.lineTo(xOf(a.length-1-i), yOf(d.m-d.s)); });
  ctx.closePath(); ctx.fillStyle = 'rgba(100,116,139,.1)'; ctx.fill();

  // mean dashed line
  ctx.beginPath(); let mv = false;
  data.forEach((d,i) => { if(d.m==null){mv=false;return;} mv ? ctx.lineTo(xOf(i),yOf(d.m)) : ctx.moveTo(xOf(i),yOf(d.m)); mv=true; });
  ctx.strokeStyle = 'rgba(100,116,139,.5)'; ctx.lineWidth = 1; ctx.setLineDash([4,4]); ctx.stroke(); ctx.setLineDash([]);

  // value line
  ctx.beginPath(); mv = false;
  data.forEach((d,i) => { if(d.v==null){mv=false;return;} mv ? ctx.lineTo(xOf(i),yOf(d.v)) : ctx.moveTo(xOf(i),yOf(d.v)); mv=true; });
  ctx.strokeStyle = lineColor; ctx.lineWidth = 2; ctx.stroke();

  // axes + grid
  ctx.strokeStyle = 'rgba(100,116,139,.2)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.l,pad.t); ctx.lineTo(pad.l,pad.t+ch); ctx.lineTo(pad.l+cw,pad.t+ch); ctx.stroke();
  ctx.fillStyle = 'rgba(100,116,139,.8)'; ctx.font = '10px "IBM Plex Mono",monospace'; ctx.textAlign = 'right';
  for (let i = 0; i <= 4; i++) {
    const v = vMin+(vMax-vMin)*i/4, y = yOf(v);
    ctx.fillText(v.toFixed(1)+'x', pad.l-4, y+3.5);
    ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(pad.l+cw,y);
    ctx.strokeStyle = 'rgba(100,116,139,.07)'; ctx.stroke();
  }
  const step = Math.max(1, Math.floor(data.length/6));
  ctx.fillStyle = 'rgba(100,116,139,.7)'; ctx.textAlign = 'center'; ctx.font = '9px "IBM Plex Mono",monospace';
  for (let i = 0; i < data.length; i += step) ctx.fillText(data[i].d ? data[i].d.slice(0,7) : '', xOf(i), H-pad.b+12);

  // hover
  if (readoutId) {
    cv.onmousemove = e => {
      const rect = cv.getBoundingClientRect();
      const idx = Math.max(0, Math.min(data.length-1, Math.round(((e.clientX-rect.left)*W/rect.width - pad.l) / cw * (data.length-1))));
      const d = data[idx];
      const rd = document.getElementById(readoutId);
      if (rd && d) rd.innerHTML = '<span style="color:var(--text2);font-family:\'IBM Plex Mono\',monospace;font-size:11px;">' + d.d + ' &nbsp;|&nbsp; Value: <strong style="color:'+lineColor+';">' + (d.v!=null?d.v.toFixed(2)+'x':'—') + '</strong> &nbsp;|&nbsp; Mean: ' + (d.m!=null?d.m.toFixed(2)+'x':'—') + ' &nbsp;|&nbsp; Z: <strong style="color:'+(d.z!=null?zColor(d.z):'var(--text3)')+';">' + (d.z!=null?(d.z>=0?'+':'')+d.z.toFixed(2)+'σ':'—') + '</strong></span>';
    };
    cv.onmouseleave = () => { const rd = document.getElementById(readoutId); if (rd) rd.innerHTML = '<span style="color:var(--text3);">Hover for values</span>'; };
  }
}

function _pdDrawOsc(peD, pbD) {
  if (!peD) { peD = _pdGetZ('pe'); pbD = _pdGetZ('pb'); }
  const cv = document.getElementById('pd-z-osc'); if (!cv) return;
  const dpr = window.devicePixelRatio||1;
  const W = cv.parentElement.clientWidth||700, H = cv.parentElement.clientHeight||180;
  cv.width = Math.round(W*dpr); cv.height = Math.round(H*dpr);
  cv.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;';
  const ctx = cv.getContext('2d');
  ctx.setTransform(dpr,0,0,dpr,0,0); ctx.clearRect(0,0,W,H);

  let oscData;
  if (_pdOscMode === 'pe')      oscData = peD.map(d => ({d:d.d, y:d.z}));
  else if (_pdOscMode === 'pb') oscData = pbD.map(d => ({d:d.d, y:d.z}));
  else {
    const pm = Object.fromEntries(peD.map(d => [d.d, d.z]));
    oscData = pbD.map(d => ({d:d.d, y: d.z!=null && pm[d.d]!=null ? (d.z+pm[d.d])/2 : null}));
  }
  if (!oscData.length) return;

  const pad = {t:10, r:18, b:28, l:48};
  const cw = W-pad.l-pad.r, ch = H-pad.t-pad.b;
  const zVals = oscData.map(d=>d.y).filter(v=>v!=null);
  const zMin = Math.min(...zVals,-2.5), zMax = Math.max(...zVals,2.5);
  const xOf = i => pad.l + (i/(oscData.length-1))*cw;
  const yOf = v => pad.t + ch*(1-(v-zMin)/(zMax-zMin));
  const y0  = yOf(0);

  // coloured fill
  oscData.forEach((d,i) => {
    if (d.y==null || i===0) return;
    const x0=xOf(i-1), x1=xOf(i), yp=yOf(oscData[i-1].y||0), yn=yOf(d.y);
    ctx.beginPath(); ctx.moveTo(x0,y0); ctx.lineTo(x0,yp); ctx.lineTo(x1,yn); ctx.lineTo(x1,y0); ctx.closePath();
    ctx.fillStyle = d.y < 0 ? 'rgba(34,197,94,.18)' : 'rgba(239,68,68,.15)'; ctx.fill();
  });

  // reference lines ±1σ ±2σ
  [-2,-1,1,2].forEach(z => {
    const y = yOf(z), a = Math.abs(z)===2 ? 0.25 : 0.4;
    ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(pad.l+cw,y);
    ctx.strokeStyle = 'rgba(100,116,139,'+a+')'; ctx.lineWidth = 1;
    ctx.setLineDash(Math.abs(z)===2 ? [3,4] : [5,3]); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle = 'rgba(100,116,139,.65)'; ctx.font = '9px "IBM Plex Mono",monospace'; ctx.textAlign = 'left';
    ctx.fillText((z>=0?'+':'')+z+'σ', pad.l+4, y-3);
  });

  // zero line
  ctx.beginPath(); ctx.moveTo(pad.l,y0); ctx.lineTo(pad.l+cw,y0);
  ctx.strokeStyle = 'rgba(100,116,139,.4)'; ctx.lineWidth = 1; ctx.stroke();

  // osc line
  const lineCol = _pdOscMode==='pe' ? 'var(--accent2)' : _pdOscMode==='pb' ? 'var(--green2)' : '#7c3aed';
  ctx.beginPath(); let mv = false;
  oscData.forEach((d,i) => { if(d.y==null){mv=false;return;} mv ? ctx.lineTo(xOf(i),yOf(d.y)) : ctx.moveTo(xOf(i),yOf(d.y)); mv=true; });
  ctx.strokeStyle = lineCol; ctx.lineWidth = 2; ctx.stroke();

  // x labels
  const step = Math.max(1, Math.floor(oscData.length/6));
  ctx.fillStyle = 'rgba(100,116,139,.7)'; ctx.textAlign = 'center'; ctx.font = '9px "IBM Plex Mono",monospace';
  for (let i = 0; i < oscData.length; i += step) ctx.fillText(oscData[i].d ? oscData[i].d.slice(0,7) : '', xOf(i), H-pad.b+12);

  // hover
  cv.onmousemove = e => {
    const rect = cv.getBoundingClientRect();
    const idx = Math.max(0, Math.min(oscData.length-1, Math.round(((e.clientX-rect.left)*W/rect.width - pad.l) / cw * (oscData.length-1))));
    const d = oscData[idx];
    const rd = document.getElementById('pd-z-osc-readout');
    if (rd && d) rd.innerHTML = '<span style="color:var(--text2);font-family:\'IBM Plex Mono\',monospace;font-size:11px;">' + d.d + ' &nbsp;|&nbsp; Z: <strong style="color:'+(d.y!=null?zColor(d.y):'var(--text3)')+';">' + (d.y!=null?(d.y>=0?'+':'')+d.y.toFixed(2)+'σ':'—') + '</strong></span>';
  };
  cv.onmouseleave = () => { const rd = document.getElementById('pd-z-osc-readout'); if (rd) rd.innerHTML = ''; };
}


