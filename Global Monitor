function drawScatter(containerId, yMetric) {
  const container = document.getElementById(containerId); if(!container) return;
  const w = container.clientWidth||600;
  const h = container.clientHeight||280;
  const pad = {t:20,r:20,b:36,l:52};
  const cw = w-pad.l-pad.r, ch = h-pad.t-pad.b;

  const colMap = {Developed:'#3b82f6',Emerging:'#f59e0b',Frontier:'#10b981',Aggregate:'#8b5cf6'};

  // Filter by selected classification
  let validData = COUNTRIES.filter(c=>c.pe&&c[yMetric]&&c.pe<100&&c[yMetric]<100);
  if(scatterCls==='all') validData = validData.filter(c=>c.classification!=='Aggregate');
  else validData = validData.filter(c=>c.classification===scatterCls);
  if(!validData.length) return;

  const xVals = validData.map(c=>c.pe);
  const yVals = validData.map(c=>c[yMetric]);
  const xMin = Math.min(...xVals)*0.88, xMax = Math.max(...xVals)*1.06;
  const yMin = Math.min(...yVals)*0.82, yMax = Math.max(...yVals)*1.08;
  const toX = v => pad.l + (v-xMin)/(xMax-xMin)*cw;
  const toY = v => pad.t + (1-(v-yMin)/(yMax-yMin))*ch;
  const meanPE = xVals.reduce((a,b)=>a+b)/xVals.length;
  const meanY  = yVals.reduce((a,b)=>a+b)/yVals.length;
  const yLabel = yMetric==='pb'?'P/B Ratio':'Forward PE';

  // Build grid lines
  let gridLines = '';
  for(let i=0;i<=5;i++){
    const gy = pad.t+i/5*ch;
    const gx = pad.l+i/5*cw;
    gridLines += `<line x1="${pad.l}" y1="${gy}" x2="${pad.l+cw}" y2="${gy}" stroke="rgba(192,184,172,.9)" stroke-width=".5"/>`;
    gridLines += `<text x="${pad.l-5}" y="${gy+3}" text-anchor="end" fill="rgba(100,116,139,.7)" font-size="9" font-family="Space Mono,monospace">${(yMax-i/5*(yMax-yMin)).toFixed(1)}</text>`;
    gridLines += `<line x1="${gx}" y1="${pad.t}" x2="${gx}" y2="${pad.t+ch}" stroke="rgba(192,184,172,.9)" stroke-width=".5"/>`;
    gridLines += `<text x="${gx}" y="${pad.t+ch+14}" text-anchor="middle" fill="rgba(100,116,139,.7)" font-size="9" font-family="Space Mono,monospace">${(xMin+i/5*(xMax-xMin)).toFixed(0)}</text>`;
  }

  // Mean crosshairs
  const mx = toX(meanPE), my = toY(meanY);
  const crosshairs = `
    <line x1="${mx}" y1="${pad.t}" x2="${mx}" y2="${pad.t+ch}" stroke="rgba(100,116,139,.22)" stroke-width="1" stroke-dasharray="3,5"/>
    <line x1="${pad.l}" y1="${my}" x2="${pad.l+cw}" y2="${my}" stroke="rgba(100,116,139,.22)" stroke-width="1" stroke-dasharray="3,5"/>`;

  // Dots
  let dots = '';
  validData.forEach((c,idx)=>{
    const x=toX(c.pe), y=toY(c[yMetric]);
    const z = scatterZMode==='classification'?(c.pe_z_cls||c.pe_z):c.pe_z;
    const r = 5 + (z!=null?Math.min(3,Math.abs(z||0)*0.8):0);
    const col = colMap[c.classification]||'#8b5cf6';
    const pez = scatterZMode==='classification'?(c.pe_z_cls||c.pe_z):c.pe_z;
    const pbz = scatterZMode==='classification'?(c.pb_z_cls||c.pb_z):c.pb_z;
    const tip = `${flag(c.name)} ${c.name} | PE:${c.pe?.toFixed(1)}x z:${zLabel(pez)} | P/B:${c.pb?.toFixed(2)}x z:${zLabel(pbz)} | Fwd:${c.best_pe?.toFixed(1)}x | Mgn:${c.prof_margin?.toFixed(1)}% | ${c.classification}`;
    dots += `<circle cx="${x}" cy="${y}" r="${r}" fill="${col}" fill-opacity=".8" stroke="rgba(0,0,0,.3)" stroke-width=".5" data-idx="${idx}" data-tip="${tip.replace(/"/g,'&quot;')}"/>`;
    const showLabel = scatterCls!=='all' || (z!=null&&Math.abs(z)>1.5);
    if(showLabel){
      const nm = ISO_MAP[c.name]||c.name.slice(0,4);
      dots += `<text x="${x}" y="${y-r-2}" text-anchor="middle" fill="rgba(226,232,240,.8)" font-size="8" font-family="Sora,sans-serif">${nm}</text>`;
    }
  });

  // Axis labels
  const axisLabels = `
    <text x="${pad.l+cw/2}" y="${h-4}" text-anchor="middle" fill="rgba(100,116,139,.8)" font-size="10" font-family="Sora,sans-serif">Trailing PE</text>
    <text transform="translate(13,${pad.t+ch/2}) rotate(-90)" text-anchor="middle" fill="rgba(100,116,139,.8)" font-size="10" font-family="Sora,sans-serif">${yLabel}</text>`;

  const svg = `<svg width="${w}" height="${h}" xmlns="http://www.w3.org/2000/svg" style="display:block;cursor:crosshair">
    ${gridLines}${crosshairs}${dots}${axisLabels}
  </svg>`;

  container.innerHTML = svg;
  container._validData = validData;
  container._yMetric = yMetric;
  container._toX = toX; container._toY = toY;

  // Attach hover to SVG circles
  container.querySelectorAll('circle').forEach(el=>{
    el.addEventListener('mouseenter', e=>{
      const c = validData[+el.dataset.idx];
      showTooltip(e.clientX, e.clientY, c);
    });
    el.addEventListener('mouseleave', ()=>document.getElementById('tooltip').classList.remove('vis'));
  });
}

function showTooltip(cx, cy, c) {
  const tt=document.getElementById('tooltip');
  const pez = scatterZMode==='classification'?(c.pe_z_cls||c.pe_z):c.pe_z;
  const pbz = scatterZMode==='classification'?(c.pb_z_cls||c.pb_z):c.pb_z;
  document.getElementById('tt-name').textContent = flag(c.name)+' '+c.name;
  document.getElementById('tt-pe').textContent = fmtX(c.pe);
  document.getElementById('tt-pez').textContent = zLabel(pez);
  document.getElementById('tt-pez').style.color = zColor(pez);
  document.getElementById('tt-pb').textContent = fmtX(c.pb,2);
  document.getElementById('tt-pbz').textContent = zLabel(pbz);
  document.getElementById('tt-pbz').style.color = zColor(pbz);
  document.getElementById('tt-bpe').textContent = fmtX(c.best_pe);
  document.getElementById('tt-pm').textContent = fmtP(c.prof_margin);
  document.getElementById('tt-cls').textContent = c.classification+' · '+c.region;
  tt.style.left = (cx+14)+'px'; tt.style.top = (cy-12)+'px';
  tt.classList.add('vis');
}

