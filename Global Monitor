// Compute ratio series: for each date present in BOTH series, ratio = primary / compare
// Then compute rolling z-score over the ratio series using zWindow
function _computeRatioData(primaryTicker, compareTicker, metric) {
  const raw1 = HISTORICAL[primaryTicker] || [];
  const raw2 = HISTORICAL[compareTicker] || [];
  const fi = metric === 'pe' ? 2 : 4;

  // Build maps: date → value
  const map2 = {};
  raw2.forEach(r => { if(r[fi] != null) map2[r[0]] = r[fi]; });

  // Build ratio series on dates where both exist
  const ratioSeries = [];
  raw1.forEach(r => {
    if(r[fi] == null) return;
    const v2 = map2[r[0]];
    if(v2 == null || v2 === 0) return;
    ratioSeries.push([r[0], r[fi] / v2]);
  });

  if (!ratioSeries.length) return [];

  const now = new Date('2026-03-06');
  let cutoff;
  if(zRange && zRange.startsWith('Y:')) {
    cutoff = new Date(parseInt(zRange.slice(2)), 0, 1);
  } else {
    const days = {['5Y']: 5*365.25, ['10Y']: 10*365.25, ['All']: 99999}[zRange] || 99999;
    cutoff = new Date(now.getTime() - days * 86400000);
  }

  // Rolling z-score (same logic as getZData)
  const W = zWindow || ratioSeries.length;
  const result = [];
  for (let i = 0; i < ratioSeries.length; i++) {
    const start = Math.max(0, i - W + 1);
    const wv = ratioSeries.slice(start, i + 1).map(r => r[1]);
    if (wv.length < 4) {
      result.push({ d: ratioSeries[i][0], v: ratioSeries[i][1], z: null, m: null, s: null });
      continue;
    }
    const mean = wv.reduce((a, b) => a + b) / wv.length;
    const s2 = wv.reduce((a, b) => a + (b - mean) ** 2, 0) / (wv.length - 1);
    const std = Math.sqrt(s2);
    result.push({
      d: ratioSeries[i][0],
      v: ratioSeries[i][1],
      z: std > 0 ? (ratioSeries[i][1] - mean) / std : 0,
      m: mean,
      s: std
    });
  }
  return result.filter(r => new Date(r.d) >= cutoff);
}

function drawRatioCharts() {
  if (!zCompareTicker) {
    const section = document.getElementById('z-ratio-section');
    if (section) section.style.display = 'none';
    return;
  }

  const priCountry = COUNTRIES.find(c => c.bloomberg === zTicker);
  const cmpCountry = COUNTRIES.find(c => c.bloomberg === zCompareTicker);
  const priName = priCountry ? priCountry.name : zTicker;
  const cmpName = cmpCountry ? cmpCountry.name : zCompareTicker;

  // Show section first so containers have dimensions
  const section = document.getElementById('z-ratio-section');
  if (!section) return;
  section.style.display = '';
  _applyRatioVisibility();

  const sectionTitle = document.getElementById('z-ratio-section-title');
  const sectionMeta  = document.getElementById('z-ratio-section-meta');
  if (sectionTitle) sectionTitle.textContent = `Relative Value — ${flag(priName)} ${priName} vs ${flag(cmpName)} ${cmpName}`;
  if (sectionMeta)  sectionMeta.textContent  = `Ratio = Primary ÷ Benchmark · below rolling mean = Primary relatively cheap`;

  // Compute ratio data
  _zRatioDataPe = _computeRatioData(zTicker, zCompareTicker, 'pe');
  _zRatioDataPb = _computeRatioData(zTicker, zCompareTicker, 'pb');

  const winLbl = zWindow === 0 ? 'Full' : zWindow + 'W';
  const rPeT = document.getElementById('z-ratio-pe-title');
  const rPbT = document.getElementById('z-ratio-pb-title');
  const rPeOT = document.getElementById('z-ratio-pe-osc-title');
  const rPbOT = document.getElementById('z-ratio-pb-osc-title');
  if (rPeT)  rPeT.textContent  = `PE Ratio: ${priName} ÷ ${cmpName}`;
  if (rPbT)  rPbT.textContent  = `P/B Ratio: ${priName} ÷ ${cmpName}`;
  if (rPeOT) rPeOT.textContent = `PE Relative Valuation Z-Score (${winLbl} rolling window)`;
  if (rPbOT) rPbOT.textContent = `P/B Relative Valuation Z-Score (${winLbl} rolling window)`;

  _updateRatioReadout('z-ratio-pe-readout', _zRatioDataPe, priName, cmpName, 'PE');
  _updateRatioReadout('z-ratio-pb-readout', _zRatioDataPb, priName, cmpName, 'P/B');

  // Defer drawing until after browser has laid out the newly-visible panels
  setTimeout(() => {
    _drawRatioCanvases();
    _attachRatioHover();
  }, 30);
}

function _drawRatioCanvases(crosshair) {
  const ci = crosshair != null ? crosshair : undefined;
  if (zRatioMetric === 'pe' || zRatioMetric === 'both') {
    if (_zRatioDataPe.length) {
      drawLineChart('z-ratio-pe',
        _zRatioDataPe.map(d => ({ d: d.d, y: d.v, m: d.m, s: d.s })),
        { bands: true, meanLine: true, dec: 3, color: '#9333ea', lw: 1.8, crosshair: ci });
      drawRatioOscillator('z-ratio-pe-osc',
        _zRatioDataPe.map(d => ({ d: d.d, y: d.z })), '#9333ea', ci);
    } else {
      _drawNoData('z-ratio-pe'); _drawNoData('z-ratio-pe-osc');
    }
  }
  if (zRatioMetric === 'pb' || zRatioMetric === 'both') {
    if (_zRatioDataPb.length) {
      drawLineChart('z-ratio-pb',
        _zRatioDataPb.map(d => ({ d: d.d, y: d.v, m: d.m, s: d.s })),
        { bands: true, meanLine: true, dec: 3, color: '#0891b2', lw: 1.8, crosshair: ci });
      drawRatioOscillator('z-ratio-pb-osc',
        _zRatioDataPb.map(d => ({ d: d.d, y: d.z })), '#0891b2', ci);
    } else {
      _drawNoData('z-ratio-pb'); _drawNoData('z-ratio-pb-osc');
    }
  }
}

function _drawNoData(canvasId) {
  const canvas = document.getElementById(canvasId); if (!canvas) return;
  const wrap = canvas.parentElement; if (!wrap) return;
  const dpr = window.devicePixelRatio || 1;
  const cssW = wrap.clientWidth || 600, cssH = wrap.clientHeight || 180;
  canvas.style.cssText = 'position:absolute;top:0;left:0;width:'+cssW+'px;height:'+cssH+'px;';
  canvas.width = Math.round(cssW * dpr); canvas.height = Math.round(cssH * dpr);
  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, cssW, cssH);
  ctx.fillStyle = 'rgba(120,110,96,.5)';
  ctx.font = '13px Inter,sans-serif'; ctx.textAlign = 'center';
  ctx.fillText('Insufficient overlapping history between the two markets', cssW / 2, cssH / 2);
}

function _updateRatioReadout(readoutId, data, priName, cmpName, metricLabel) {
  const el = document.getElementById(readoutId);
  if (!el) return;
  if (!data || !data.length) {
    el.innerHTML = `<span style="color:var(--text3);">Insufficient overlapping history to compute ratio</span>`;
    return;
  }
  const last = data[data.length - 1];
  const zStr = last.z != null ? (last.z >= 0 ? '+' : '') + last.z.toFixed(2) + 'σ' : '–';
  const zCol = zColor(last.z);
  const signal = last.z == null ? '–'
    : last.z < -2 ? 'Deeply cheap vs benchmark'
    : last.z < -1 ? 'Cheap vs benchmark'
    : last.z < -0.5 ? 'Mildly cheap vs benchmark'
    : last.z < 0.5 ? 'In line with history'
    : last.z < 1 ? 'Mildly expensive vs benchmark'
    : last.z < 2 ? 'Expensive vs benchmark'
    : 'Deeply expensive vs benchmark';
  const pctile = (() => {
    const zVals = data.map(d => d.z).filter(v => v != null);
    if (!zVals.length || last.z == null) return null;
    return Math.round(zVals.filter(v => v <= last.z).length / zVals.length * 100);
  })();
  el.innerHTML = `
    <div class="cr-item"><span class="cr-lbl">${metricLabel} Ratio</span><span class="cr-val">${last.v != null ? last.v.toFixed(3) + 'x' : '–'}</span></div>
    <div class="cr-item"><span class="cr-lbl">Rolling Mean</span><span class="cr-val">${last.m != null ? last.m.toFixed(3) + 'x' : '–'}</span></div>
    <div class="cr-item"><span class="cr-lbl">Z-Score</span><span class="cr-val" style="color:${zCol};font-weight:700;">${zStr}</span></div>
    <div class="cr-item"><span class="cr-lbl">Percentile</span><span class="cr-val">${pctile != null ? pctile + 'th' : '–'}</span></div>
    <div class="cr-item"><span class="cr-lbl">Signal</span><span class="cr-val" style="color:${zCol}">${signal}</span></div>`;
}

function drawRatioOscillator(canvasId, data, lineColor, crosshairIdx) {
  const canvas = document.getElementById(canvasId); if (!canvas) return;
  const wrap = canvas.parentElement; if (!wrap) return;
  const dpr = window.devicePixelRatio || 1;
  const cssW = wrap.clientWidth || 800, cssH = wrap.clientHeight || 130;
  canvas.style.cssText = 'position:absolute;top:0;left:0;width:'+cssW+'px;height:'+cssH+'px;';
  const pw = Math.round(cssW * dpr), ph = Math.round(cssH * dpr);
  if (canvas.width !== pw || canvas.height !== ph) { canvas.width = pw; canvas.height = ph; }
  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, cssW, cssH);

  const pad = { t: 12, r: 16, b: 28, l: 50 };
  const cw = cssW - pad.l - pad.r, ch = cssH - pad.t - pad.b;
  const yMin = -3.5, yMax = 3.5;
  const n = data.length;
  const toX = i => pad.l + (n > 1 ? i / (n - 1) * cw : cw / 2);
  const toY = v => pad.t + (1 - (v - yMin) / (yMax - yMin)) * ch;

  // Zone fills
  ctx.fillStyle = 'rgba(139,32,32,.07)'; ctx.fillRect(pad.l, toY(1), cw, toY(0) - toY(1));
  ctx.fillStyle = 'rgba(139,32,32,.13)'; ctx.fillRect(pad.l, toY(2), cw, toY(1) - toY(2));
  ctx.fillStyle = 'rgba(29,92,58,.07)';  ctx.fillRect(pad.l, toY(0), cw, toY(-1) - toY(0));
  ctx.fillStyle = 'rgba(29,92,58,.13)';  ctx.fillRect(pad.l, toY(-1), cw, toY(-2) - toY(-1));

  // Sigma reference lines
  [0, 1, -1, 2, -2].forEach(sig => {
    const y = toY(sig);
    ctx.strokeStyle = sig === 0 ? 'rgba(26,22,18,.4)' : Math.abs(sig) === 2 ? 'rgba(120,30,30,.3)' : 'rgba(150,140,125,.25)';
    ctx.lineWidth = sig === 0 ? 1 : 0.5;
    ctx.setLineDash(sig === 0 ? [] : [2, 4]);
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(pad.l + cw, y); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle = Math.abs(sig) === 2 ? 'rgba(139,32,32,.7)' : 'rgba(120,110,96,.65)';
    ctx.font = '8px IBM Plex Mono,monospace'; ctx.textAlign = 'right';
    ctx.fillText((sig > 0 ? '+' : '') + sig + 'σ', pad.l - 3, y + 3);
  });

  // X-axis dates
  const step = Math.max(1, Math.floor(n / 5));
  for (let i = 0; i < n; i += step) {
    if (data[i]?.d) {
      ctx.fillStyle = 'rgba(122,110,96,.55)'; ctx.font = '8px IBM Plex Mono,monospace'; ctx.textAlign = 'center';
      ctx.fillText(data[i].d.slice(0, 7), toX(i), pad.t + ch + 14);
    }
  }

  if (n < 2) return;

  // Colour-fill under/over zero
  const y0 = toY(0);
  const hexToRgb = hex => { const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); return `${r},${g},${b}`; };
  const rgb = lineColor.startsWith('#') ? hexToRgb(lineColor) : '147,51,234';
  data.forEach((d, i) => {
    if (d.y == null || i === 0) return;
    const x1 = toX(i - 1), x2 = toX(i);
    const y1 = toY(Math.max(yMin, Math.min(yMax, data[i - 1].y || 0)));
    const y2 = toY(Math.max(yMin, Math.min(yMax, d.y)));
    ctx.fillStyle = d.y > 0 ? `rgba(139,32,32,.12)` : `rgba(29,92,58,.12)`;
    if (d.y > 0) ctx.fillRect(x1, Math.min(y1, y2), x2 - x1, y0 - Math.min(y1, y2));
    else ctx.fillRect(x1, y0, x2 - x1, Math.max(y1, y2) - y0);
  });

  // Main line
  ctx.strokeStyle = lineColor; ctx.lineWidth = 1.8; ctx.beginPath();
  let first = true;
  data.forEach((d, i) => {
    if (d.y == null) { first = true; return; }
    const x = toX(i), y = toY(Math.max(yMin, Math.min(yMax, d.y)));
    first ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    first = false;
  });
  ctx.stroke();

  // Crosshair
  if (crosshairIdx != null && crosshairIdx >= 0 && crosshairIdx < n) {
    const cx = toX(crosshairIdx);
    ctx.strokeStyle = 'rgba(42,74,127,.5)'; ctx.lineWidth = 1; ctx.setLineDash([]);
    ctx.beginPath(); ctx.moveTo(cx, pad.t); ctx.lineTo(cx, pad.t + ch); ctx.stroke();
    const d = data[crosshairIdx];
    if (d?.y != null) {
      const cy = toY(Math.max(yMin, Math.min(yMax, d.y)));
      ctx.beginPath(); ctx.arc(cx, cy, 3.5, 0, Math.PI * 2);
      ctx.fillStyle = lineColor; ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,.6)'; ctx.lineWidth = 1; ctx.stroke();
    }
  }
}

function _attachRatioHover() {
  const version = ++_zRatioHoverVersion;
  const ids = ['z-ratio-pe', 'z-ratio-pe-osc', 'z-ratio-pb', 'z-ratio-pb-osc'];
  ids.forEach(id => {
    const canvas = document.getElementById(id); if (!canvas) return;
    canvas.onmousemove = e => {
      if (version !== _zRatioHoverVersion) return;
      const rect = canvas.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      const len = Math.max(_zRatioDataPe.length, _zRatioDataPb.length, 1);
      const idx = Math.max(0, Math.min(len - 1, Math.round(pct * (len - 1))));
      if (idx === _zRatioCrosshairIdx) return;
      _zRatioCrosshairIdx = idx;
      if (!_zRatioRafPending) {
        _zRatioRafPending = true;
        requestAnimationFrame(() => {
          _zRatioRafPending = false;
          _drawRatioCanvases(_zRatioCrosshairIdx);
        });
      }
      // Update readout bars on hover
      const dPe = _zRatioDataPe[Math.min(idx, _zRatioDataPe.length - 1)];
      const dPb = _zRatioDataPb[Math.min(idx, _zRatioDataPb.length - 1)];
      const fmtReadout = (d, metric) => {
        if (!d) return '';
        const zStr = d.z != null ? (d.z >= 0 ? '+' : '') + d.z.toFixed(2) + 'σ' : '–';
        const sig = d.z == null ? '–' : d.z < -1 ? 'Cheap vs benchmark' : d.z > 1 ? 'Expensive vs benchmark' : 'In line';
        return `<div class="cr-item"><span class="cr-lbl">Date</span><span class="cr-val">${d.d}</span></div>
          <div class="cr-item"><span class="cr-lbl">${metric} Ratio</span><span class="cr-val">${d.v!=null?d.v.toFixed(3)+'x':'–'}</span></div>
          <div class="cr-item"><span class="cr-lbl">Mean</span><span class="cr-val">${d.m!=null?d.m.toFixed(3)+'x':'–'}</span></div>
          <div class="cr-item"><span class="cr-lbl">+1σ / −1σ</span><span class="cr-val">${d.m!=null&&d.s!=null?(d.m+d.s).toFixed(3)+' / '+(d.m-d.s).toFixed(3):'–'}</span></div>
          <div class="cr-item"><span class="cr-lbl">Z-Score</span><span class="cr-val" style="color:${zColor(d.z)};font-weight:700">${zStr}</span></div>
          <div class="cr-item"><span class="cr-lbl">Signal</span><span class="cr-val" style="color:${zColor(d.z)}">${sig}</span></div>`;
      };
      const peRo  = document.getElementById('z-ratio-pe-readout');
      const pbRo  = document.getElementById('z-ratio-pb-readout');
      const peOscRo = document.getElementById('z-ratio-pe-osc-readout');
      const pbOscRo = document.getElementById('z-ratio-pb-osc-readout');
      if (peRo  && dPe) peRo.innerHTML  = fmtReadout(dPe, 'PE');
      if (pbRo  && dPb) pbRo.innerHTML  = fmtReadout(dPb, 'P/B');
      if (peOscRo && dPe) peOscRo.innerHTML = `<div class="cr-item"><span class="cr-lbl">PE Ratio Z</span><span class="cr-val" style="color:${zColor(dPe?.z)};font-weight:700">${dPe?.z!=null?(dPe.z>=0?'+':'')+dPe.z.toFixed(2)+'σ':'–'}</span></div><div class="cr-item"><span class="cr-lbl">Date</span><span class="cr-val">${dPe?.d||''}</span></div>`;
      if (pbOscRo && dPb) pbOscRo.innerHTML = `<div class="cr-item"><span class="cr-lbl">P/B Ratio Z</span><span class="cr-val" style="color:${zColor(dPb?.z)};font-weight:700">${dPb?.z!=null?(dPb.z>=0?'+':'')+dPb.z.toFixed(2)+'σ':'–'}</span></div>`;
    };
    canvas.onmouseleave = () => {
      if (version !== _zRatioHoverVersion) return;
      _zRatioCrosshairIdx = -1;
      _drawRatioCanvases();
      // Restore snapshot readouts
      const priCountry = COUNTRIES.find(c => c.bloomberg === zTicker);
      const cmpCountry = COUNTRIES.find(c => c.bloomberg === zCompareTicker);
      _updateRatioReadout('z-ratio-pe-readout', _zRatioDataPe, priCountry?.name||'', cmpCountry?.name||'', 'PE');
      _updateRatioReadout('z-ratio-pb-readout', _zRatioDataPb, priCountry?.name||'', cmpCountry?.name||'', 'P/B');
      ['z-ratio-pe-osc-readout','z-ratio-pb-osc-readout'].forEach(id => {
        const el = document.getElementById(id); if(el) el.innerHTML = '';
      });
    };
  });
}

function drawLineChart(canvasId, data, opts={}) {
  const canvas=document.getElementById(canvasId); if(!canvas) return;
  const wrap=canvas.parentElement; if(!wrap) return;
  const dpr=window.devicePixelRatio||1;
  const cssW=wrap.clientWidth||800;
  const cssH=wrap.clientHeight||200;
  canvas.style.cssText='position:absolute;top:0;left:0;width:'+cssW+'px;height:'+cssH+'px;';
  const pw=Math.round(cssW*dpr), ph=Math.round(cssH*dpr);
  if(canvas.width!==pw||canvas.height!==ph){ canvas.width=pw; canvas.height=ph; }
  const ctx=canvas.getContext('2d');
  ctx.setTransform(dpr,0,0,dpr,0,0);
  ctx.clearRect(0,0,cssW,cssH);
  const w=cssW, h=cssH;

  const pad={t:16,r:16,b:30,l:50};
  const cw=w-pad.l-pad.r, ch=h-pad.t-pad.b;

  // Combine primary + overlay for y-range
  const allY = [...data, ...(opts.overlay?.data||[])].map(d=>d.y).filter(v=>v!=null&&!isNaN(v));
  if(!allY.length) return;
  let yMin=opts.yMin!==undefined?opts.yMin:Math.min(...allY);
  let yMax=opts.yMax!==undefined?opts.yMax:Math.max(...allY);
  const yp=(yMax-yMin)*0.08;
  if(opts.yMin===undefined) yMin-=yp; if(opts.yMax===undefined) yMax+=yp;
  if(yMin===yMax){yMin-=1;yMax+=1;}

  const toX=i=>pad.l+i/(data.length-1||1)*cw;
  const toY=v=>pad.t+(1-(v-yMin)/(yMax-yMin))*ch;

  // grid
  ctx.strokeStyle='rgba(192,184,172,.9)'; ctx.lineWidth=0.5;
  for(let i=0;i<=4;i++){
    const y=pad.t+i/4*ch;
    ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(pad.l+cw,y);ctx.stroke();
    ctx.fillStyle='rgba(122,110,96,.75)';ctx.font='9px IBM Plex Mono,monospace';ctx.textAlign='right';
    ctx.fillText((yMax-i/4*(yMax-yMin)).toFixed(opts.dec!==undefined?opts.dec:1),pad.l-4,y+3);
  }
  // x dates
  const step=Math.max(1,Math.floor(data.length/6));
  for(let i=0;i<data.length;i+=step){
    const x=toX(i);
    ctx.fillStyle='rgba(122,110,96,.65)';ctx.font='9px IBM Plex Mono,monospace';ctx.textAlign='center';
    ctx.fillText(data[i].d.slice(0,7),x,pad.t+ch+14);
  }

  // zero line
  if(opts.zeroLine){
    const y0=toY(0);
    ctx.strokeStyle='rgba(122,110,96,.45)';ctx.lineWidth=1;ctx.setLineDash([4,4]);
    ctx.beginPath();ctx.moveTo(pad.l,y0);ctx.lineTo(pad.l+cw,y0);ctx.stroke();
    ctx.setLineDash([]);

    // sigma bands with colored backgrounds
    const sigmas = [{v:1,fill:'rgba(139,32,32,.07)'},{v:-1,fill:'rgba(29,92,58,.07)'},{v:2,fill:'rgba(139,32,32,.06)'},{v:-2,fill:'rgba(29,92,58,.06)'}];
    if(opts.colorBands) {
      // fill ±1σ zone (cheap)
      const y1n=toY(-1), y1p=toY(1);
      // shade cheap zone
      ctx.fillStyle='rgba(29,92,58,.08)';
      ctx.fillRect(pad.l,y0,cw,y1n-y0);
      // shade expensive zone
      ctx.fillStyle='rgba(139,32,32,.08)';
      ctx.fillRect(pad.l,y1p,cw,y0-y1p);
      // shade deep zones
      const y2n=toY(-2), y2p=toY(2);
      ctx.fillStyle='rgba(29,92,58,.10)';
      ctx.fillRect(pad.l,y0,cw,y2n-y0);
      ctx.fillStyle='rgba(139,32,32,.10)';
      if(y2p<pad.t) ctx.fillRect(pad.l,pad.t,cw,y0-pad.t);
      else ctx.fillRect(pad.l,y2p,cw,y0-y2p);
    }

    [1,-1,2,-2].forEach(sig=>{
      const ys=toY(sig);
      ctx.strokeStyle=Math.abs(sig)===2?'rgba(139,32,32,.25)':'rgba(122,110,96,.22)';
      ctx.lineWidth=Math.abs(sig)===2?0.8:0.5;ctx.setLineDash([2,4]);
      ctx.beginPath();ctx.moveTo(pad.l,ys);ctx.lineTo(pad.l+cw,ys);ctx.stroke();ctx.setLineDash([]);
      ctx.fillStyle=Math.abs(sig)===2?'rgba(139,32,32,.6)':'rgba(122,110,96,.55)';
      ctx.font='8px IBM Plex Mono,monospace';ctx.textAlign='right';
      ctx.fillText((sig>0?'+':'')+sig+'σ',pad.l-3,ys+3);
    });
  }

  // bands (±1σ shaded area around rolling mean)
  if(opts.bands && data.length > 0) {
    const hasBands = data.some(d => d.m != null && d.s != null);
    if(hasBands) {
      // upper edge: walk forward skipping nulls
      ctx.beginPath();
      let first = true;
      data.forEach((d,i) => {
        if(d.m == null || d.s == null) return;
        if(first){ ctx.moveTo(toX(i), toY(d.m + d.s)); first = false; }
        else ctx.lineTo(toX(i), toY(d.m + d.s));
      });
      // lower edge: walk backward
      for(let i = data.length - 1; i >= 0; i--) {
        const d = data[i];
        if(d.m == null || d.s == null) continue;
        ctx.lineTo(toX(i), toY(d.m - d.s));
      }
      ctx.closePath();
      ctx.fillStyle = 'rgba(42,74,127,.08)';
      ctx.fill();
    }
  }

  // mean line
  if(opts.meanLine && data.length > 0) {
    const hasMean = data.some(d => d.m != null);
    if(hasMean) {
      ctx.strokeStyle='rgba(122,110,96,.45)'; ctx.lineWidth=1; ctx.setLineDash([3,4]);
      ctx.beginPath(); let firstM = true;
      data.forEach((d,i) => {
        if(d.m == null) { firstM = true; return; }
        if(firstM){ ctx.moveTo(toX(i), toY(d.m)); firstM = false; }
        else ctx.lineTo(toX(i), toY(d.m));
      });
      ctx.stroke(); ctx.setLineDash([]);
    }
  }

  // colored fill for oscillator (primary)
  if(opts.colorFill){
    const y0=toY(0);
    data.forEach((d,i)=>{
      if(d.y==null||i===0) return;
      const x1=toX(i-1),x2=toX(i);
      const y1=toY(data[i-1].y||0),y2=toY(d.y);
      const pos=d.y>0;
      ctx.fillStyle=pos?'rgba(139,32,32,.15)':'rgba(29,92,58,.15)';
      if(pos) ctx.fillRect(x1,Math.min(y1,y2),x2-x1,y0-Math.min(y1,y2));
      else ctx.fillRect(x1,y0,x2-x1,Math.max(y1,y2)-y0);
    });
  }

  // main line (primary)
  ctx.strokeStyle=opts.color||'var(--accent)';ctx.lineWidth=opts.lw||1.5;
  ctx.beginPath();let firstL=true;
  data.forEach((d,i)=>{
    if(d.y==null){firstL=true;return;}
    const x=toX(i),y=toY(d.y);
    if(firstL){ctx.moveTo(x,y);firstL=false;}else ctx.lineTo(x,y);
  });
  ctx.stroke();

  // overlay (compare) line
  if(opts.overlay&&opts.overlay.data&&opts.overlay.data.length) {
    const od = opts.overlay.data;
    const oc = opts.overlay.color||'#f59e0b';
    // Map overlay to same x-domain as primary (by index proportion)
    ctx.strokeStyle=oc;ctx.lineWidth=opts.lw||1.5;ctx.setLineDash([4,3]);
    ctx.beginPath();let firstO=true;
    od.forEach((d,i)=>{
      if(d.y==null){firstO=true;return;}
      // Scale overlay to same x domain
      const ox=pad.l+i/(od.length-1||1)*cw;
      const oy=toY(d.y);
      if(firstO){ctx.moveTo(ox,oy);firstO=false;}else ctx.lineTo(ox,oy);
    });
    ctx.stroke();ctx.setLineDash([]);
  }

  // crosshair
  if(opts.crosshair!=null&&opts.crosshair>=0&&opts.crosshair<data.length){
    const d=data[opts.crosshair];
    const cx=toX(opts.crosshair);
    ctx.strokeStyle='rgba(42,74,127,.5)';ctx.lineWidth=1;ctx.setLineDash([]);
    ctx.beginPath();ctx.moveTo(cx,pad.t);ctx.lineTo(cx,pad.t+ch);ctx.stroke();
    if(d.y!=null){
      const cy=toY(d.y);
      ctx.beginPath();ctx.arc(cx,cy,3.5,0,Math.PI*2);
      ctx.fillStyle=opts.color||'var(--accent)';ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,.7)';ctx.lineWidth=1;ctx.stroke();
    }
  }
}

