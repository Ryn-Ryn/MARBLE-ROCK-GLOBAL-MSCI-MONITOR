}

function drawZZScatter() {
  const container = document.getElementById('sc-zz');
  if (!container) return;
  const w = container.clientWidth || 700;
  const h = container.clientHeight || 400;
  const pad = {t:28, r:24, b:50, l:60};
  const cw = w - pad.l - pad.r;
  const ch = h - pad.t - pad.b;

  const colMap = {Developed:'#3b82f6', Emerging:'#f59e0b', Frontier:'#10b981', Aggregate:'#8b5cf6'};

  let data = COUNTRIES.filter(c => c.pe_z != null && c.pb_z != null && c.classification !== 'Aggregate');
  if (qScatterCls !== 'all') data = data.filter(c => c.classification === qScatterCls);
  if (!data.length) return;

  const getZ = (c, field) => {
    if (qScatterZMode === 'classification') {
      return field === 'pe' ? (c.pe_z_cls ?? c.pe_z) : (c.pb_z_cls ?? c.pb_z);
    }
    return field === 'pe' ? c.pe_z : c.pb_z;
  };

  const xVals = data.map(c => getZ(c, 'pe'));
  const yVals = data.map(c => getZ(c, 'pb'));
  const absMax = Math.max(
    Math.max(...xVals.map(Math.abs)),
    Math.max(...yVals.map(Math.abs))
  ) * 1.2 || 3;
  const axisRange = Math.ceil(absMax * 2) / 2;

  const toX = v => pad.l + (v + axisRange) / (axisRange * 2) * cw;
  const toY = v => pad.t + (1 - (v + axisRange) / (axisRange * 2)) * ch;
  const cx0 = toX(0), cy0 = toY(0);

  // Quadrant backgrounds
  const quadBgs = `
    <rect x="${pad.l}" y="${cy0}" width="${cx0-pad.l}" height="${pad.t+ch-cy0}" fill="rgba(29,92,58,.12)"/>
    <rect x="${cx0}" y="${pad.t}" width="${pad.l+cw-cx0}" height="${cy0-pad.t}" fill="rgba(139,32,32,.10)"/>
    <rect x="${pad.l}" y="${pad.t}" width="${cx0-pad.l}" height="${cy0-pad.t}" fill="rgba(192,184,172,.18)"/>
    <rect x="${cx0}" y="${cy0}" width="${pad.l+cw-cx0}" height="${pad.t+ch-cy0}" fill="rgba(192,184,172,.18)"/>
  `;

  // Quadrant labels
  const qlSize = 9;
  const quadLabels = `
    <text x="${pad.l+6}" y="${pad.t+ch-6}" font-size="${qlSize}" font-family="IBM Plex Mono,monospace" fill="rgba(29,92,58,.75)" font-weight="700" letter-spacing="0.5">◼ DOUBLY CHEAP</text>
    <text x="${cx0+6}" y="${pad.t+14}" font-size="${qlSize}" font-family="IBM Plex Mono,monospace" fill="rgba(139,32,32,.75)" font-weight="700" letter-spacing="0.5">◼ DOUBLY EXPENSIVE</text>
    <text x="${pad.l+6}" y="${pad.t+14}" font-size="${qlSize}" font-family="IBM Plex Mono,monospace" fill="rgba(122,64,16,.65)" font-weight="600" letter-spacing="0.3">PB RICH / PE CHEAP</text>
    <text x="${cx0+6}" y="${pad.t+ch-6}" font-size="${qlSize}" font-family="IBM Plex Mono,monospace" fill="rgba(122,64,16,.65)" font-weight="600" letter-spacing="0.3">PE RICH / PB CHEAP</text>
  `;

  // Grid lines
  let gridLines = '';
  for (let v = -Math.floor(axisRange); v <= Math.floor(axisRange); v += 0.5) {
    if (Math.abs(v) > axisRange) continue;
    const gx = toX(v), gy = toY(v);
    const isZero = v === 0;
    const col = isZero ? 'rgba(26,22,18,.45)' : 'rgba(192,184,172,.55)';
    const sw = isZero ? '1.2' : '.4';
    gridLines += `<line x1="${gx}" y1="${pad.t}" x2="${gx}" y2="${pad.t+ch}" stroke="${col}" stroke-width="${sw}" ${!isZero?'stroke-dasharray="2,4"':''}/>`;
    gridLines += `<line x1="${pad.l}" y1="${gy}" x2="${pad.l+cw}" y2="${gy}" stroke="${col}" stroke-width="${sw}" ${!isZero?'stroke-dasharray="2,4"':''}/>`;
    if (Number.isInteger(v)) {
      gridLines += `<text x="${gx}" y="${pad.t+ch+14}" text-anchor="middle" fill="rgba(100,116,139,.8)" font-size="9" font-family="IBM Plex Mono,monospace">${v>0?'+'+v:v}&#963;</text>`;
      gridLines += `<text x="${pad.l-6}" y="${gy+3}" text-anchor="end" fill="rgba(100,116,139,.8)" font-size="9" font-family="IBM Plex Mono,monospace">${v>0?'+'+v:v}&#963;</text>`;
    }
  }

  // Dots
  let dots = '';
  data.forEach((c, idx) => {
    const pez = getZ(c, 'pe');
    const pbz = getZ(c, 'pb');
    const x = toX(pez), y = toY(pbz);
    const col = colMap[c.classification] || '#8b5cf6';
    const r = 5.5;
    const doublyCheap = pez < 0 && pbz < 0;
    const doublyExp   = pez > 0 && pbz > 0;
    const strokeCol   = doublyCheap ? '#1d5c3a' : doublyExp ? '#8b2020' : 'rgba(0,0,0,.3)';
    const strokeW     = (doublyCheap || doublyExp) ? '1.5' : '.5';
    const tip = `${flag(c.name)} ${c.name} | PE Z:${(pez>=0?'+':'')+pez.toFixed(2)}&sigma; | P/B Z:${(pbz>=0?'+':'')+pbz.toFixed(2)}&sigma; | ${c.classification}`;
    dots += `<circle cx="${x}" cy="${y}" r="${r}" fill="${col}" fill-opacity=".82" stroke="${strokeCol}" stroke-width="${strokeW}" data-idx="${idx}" data-tip="${tip.replace(/"/g,'&quot;')}"/>`;
    const nm = ISO_MAP[c.name] || c.name.slice(0,3);
    dots += `<text x="${x}" y="${y-r-2}" text-anchor="middle" fill="rgba(26,22,18,.72)" font-size="7.5" font-family="IBM Plex Mono,monospace" font-weight="600">${nm}</text>`;
  });

  // Axis labels
  const axisLabels = `
    <text x="${pad.l+cw/2}" y="${h-6}" text-anchor="middle" fill="rgba(100,116,139,.9)" font-size="10" font-family="Inter,sans-serif" font-weight="600">&#8592; Cheap &nbsp;&nbsp; PE Z-Score &nbsp;&nbsp; Expensive &#8594;</text>
    <text transform="translate(14,${pad.t+ch/2}) rotate(-90)" text-anchor="middle" fill="rgba(100,116,139,.9)" font-size="10" font-family="Inter,sans-serif" font-weight="600">&#8592; Cheap &nbsp;&nbsp; P/B Z-Score &nbsp;&nbsp; Expensive &#8594;</text>
  `;

  const svg = `<svg width="${w}" height="${h}" xmlns="http://www.w3.org/2000/svg" style="display:block;cursor:crosshair">
    ${quadBgs}${gridLines}${quadLabels}${dots}${axisLabels}
  </svg>`;

  container.innerHTML = svg;
  container._data = data;

  container.querySelectorAll('circle').forEach(el => {
    el.addEventListener('mouseenter', e => {
      const c = data[+el.dataset.idx];
      showTooltip(e.clientX, e.clientY, c);
      el.style.cursor = 'pointer';
    });
    el.addEventListener('mouseleave', () => document.getElementById('tooltip').classList.remove('vis'));
    el.addEventListener('click', e => {
      const c = data[+el.dataset.idx];
      document.getElementById('tooltip').classList.remove('vis');
      switchTab('screener', document.querySelector('.nb:nth-child(2)'));
      setTimeout(() => openProfileDetail(c.name), 60);
    });
  });
}

