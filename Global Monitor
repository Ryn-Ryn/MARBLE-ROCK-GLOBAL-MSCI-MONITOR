function drawDualOscillator(canvasId, peData, pbData, opts={}) {
  const canvas=document.getElementById(canvasId); if(!canvas) return;
  const wrap=canvas.parentElement; if(!wrap) return;
  const dpr=window.devicePixelRatio||1;
  const cssW=wrap.clientWidth||800, cssH=wrap.clientHeight||140;
  canvas.style.cssText='position:absolute;top:0;left:0;width:'+cssW+'px;height:'+cssH+'px;';
  const pw=Math.round(cssW*dpr), ph=Math.round(cssH*dpr);
  if(canvas.width!==pw||canvas.height!==ph){canvas.width=pw;canvas.height=ph;}
  const ctx=canvas.getContext('2d');
  ctx.setTransform(dpr,0,0,dpr,0,0);
  ctx.clearRect(0,0,cssW,cssH);
  const pad={t:12,r:16,b:28,l:50};
  const cw=cssW-pad.l-pad.r, ch=cssH-pad.t-pad.b;
  const yMin=-3.5, yMax=3.5;
  const mode=opts.mode||'pe';
  const peW=(opts.peWeight!=null?opts.peWeight:50)/100;
  const pbW=1-peW;

  // Build the active data series
  let activeData=[];
  if(mode==='pe') activeData=peData;
  else if(mode==='pb') activeData=pbData;
  else { // combined: weighted blend on matching indices
    const len=Math.max(peData.length,pbData.length);
    for(let i=0;i<len;i++){
      const p=peData[i], b=pbData[Math.min(i,pbData.length-1)];
      const y=(p&&p.y!=null&&b&&b.y!=null)?(p.y*peW+b.y*pbW):(p&&p.y!=null?p.y:b&&b.y!=null?b.y:null);
      activeData.push({d:(p||b).d,y});
    }
  }

  const refData=activeData.length?activeData:peData;
  const toX=i=>pad.l+i/(Math.max(refData.length,2)-1)*cw;
  const toY=v=>pad.t+(1-(v-yMin)/(yMax-yMin))*ch;

  // Background bands
  ctx.fillStyle='rgba(139,32,32,.07)'; ctx.fillRect(pad.l,toY(1),cw,toY(0)-toY(1));
  ctx.fillStyle='rgba(139,32,32,.12)'; ctx.fillRect(pad.l,toY(2),cw,toY(1)-toY(2));
  ctx.fillStyle='rgba(29,92,58,.07)';  ctx.fillRect(pad.l,toY(0),cw,toY(-1)-toY(0));
  ctx.fillStyle='rgba(29,92,58,.12)';  ctx.fillRect(pad.l,toY(-1),cw,toY(-2)-toY(-1));

  // Grid lines
  [0,1,-1,2,-2].forEach(sig=>{
    const y=toY(sig);
    ctx.strokeStyle=sig===0?'rgba(26,22,18,.35)':Math.abs(sig)===2?'rgba(139,32,32,.25)':'rgba(122,110,96,.2)';
    ctx.lineWidth=sig===0?1:.5; ctx.setLineDash(sig===0?[]:[2,4]);
    ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(pad.l+cw,y);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle=Math.abs(sig)===2?'rgba(139,32,32,.65)':'rgba(122,110,96,.6)';
    ctx.font='8px IBM Plex Mono,monospace';ctx.textAlign='right';
    ctx.fillText((sig>0?'+':'')+sig+'σ',pad.l-3,y+3);
  });

  // Date labels
  const step=Math.max(1,Math.floor(refData.length/5));
  for(let i=0;i<refData.length;i+=step){
    ctx.fillStyle='rgba(122,110,96,.55)';ctx.font='8px IBM Plex Mono,monospace';ctx.textAlign='center';
    ctx.fillText(refData[i].d.slice(0,7),toX(i),pad.t+ch+14);
  }

  // Draw PE line (when mode is 'pe' or 'combined')
  if(mode==='pe'||mode==='combined'){
    const data=mode==='combined'?peData:activeData;
    const color=mode==='combined'?'rgba(61,107,175,0.45)':'#3d6baf';
    const lw=mode==='combined'?1.2:1.8;
    // Filled area for single mode
    if(mode==='pe'&&data.length>1){
      const y0=toY(0);
      data.forEach((d,i)=>{
        if(d.y==null||i===0) return;
        const x1=toX(i-1),x2=toX(i);
        const y1=toY(Math.max(yMin,Math.min(yMax,data[i-1].y||0)));
        const y2=toY(Math.max(yMin,Math.min(yMax,d.y)));
        ctx.fillStyle=d.y>0?'rgba(61,107,175,.12)':'rgba(42,122,79,.12)';
        if(d.y>0) ctx.fillRect(x1,Math.min(y1,y2),x2-x1,y0-Math.min(y1,y2));
        else ctx.fillRect(x1,y0,x2-x1,Math.max(y1,y2)-y0);
      });
    }
    ctx.strokeStyle=color;ctx.lineWidth=lw;ctx.beginPath();let f=true;
    data.forEach((d,i)=>{if(d.y==null){f=true;return;}const x=toX(i),y=toY(Math.max(yMin,Math.min(yMax,d.y)));f?ctx.moveTo(x,y):ctx.lineTo(x,y);f=false;});ctx.stroke();
  }

  // Draw PB line (when mode is 'pb' or 'combined')
  if(mode==='pb'||mode==='combined'){
    const data=mode==='combined'?pbData:activeData;
    const color=mode==='combined'?'rgba(42,122,79,0.45)':'#2a7a4f';
    const lw=mode==='combined'?1.2:1.8;
    if(mode==='pb'&&data.length>1){
      const y0=toY(0);
      data.forEach((d,i)=>{
        if(d.y==null||i===0) return;
        const x1=toX(i-1),x2=toX(i);
        const y1=toY(Math.max(yMin,Math.min(yMax,data[i-1].y||0)));
        const y2=toY(Math.max(yMin,Math.min(yMax,d.y)));
        ctx.fillStyle=d.y>0?'rgba(42,122,79,.12)':'rgba(42,122,79,.08)';
        if(d.y>0) ctx.fillRect(x1,Math.min(y1,y2),x2-x1,y0-Math.min(y1,y2));
        else ctx.fillRect(x1,y0,x2-x1,Math.max(y1,y2)-y0);
      });
    }
    ctx.strokeStyle=color;ctx.lineWidth=lw;ctx.beginPath();let f=true;
    data.forEach((d,i)=>{if(d.y==null){f=true;return;}const x=toX(i),y=toY(Math.max(yMin,Math.min(yMax,d.y)));f?ctx.moveTo(x,y):ctx.lineTo(x,y);f=false;});ctx.stroke();
  }

  // Draw combined blended line (bold single line on top)
  if(mode==='combined'&&activeData.length>1){
    const y0=toY(0);
    // Filled area
    activeData.forEach((d,i)=>{
      if(d.y==null||i===0) return;
      const x1=toX(i-1),x2=toX(i);
      const y1=toY(Math.max(yMin,Math.min(yMax,activeData[i-1].y||0)));
      const y2=toY(Math.max(yMin,Math.min(yMax,d.y)));
      ctx.fillStyle=d.y>0?'rgba(124,58,237,.10)':'rgba(29,92,58,.10)';
      if(d.y>0) ctx.fillRect(x1,Math.min(y1,y2),x2-x1,y0-Math.min(y1,y2));
      else ctx.fillRect(x1,y0,x2-x1,Math.max(y1,y2)-y0);
    });
    ctx.strokeStyle='#7c3aed';ctx.lineWidth=2.2;ctx.beginPath();let f=true;
    activeData.forEach((d,i)=>{if(d.y==null){f=true;return;}const x=toX(i),y=toY(Math.max(yMin,Math.min(yMax,d.y)));f?ctx.moveTo(x,y):ctx.lineTo(x,y);f=false;});ctx.stroke();
  }

  // Crosshair
  if(opts.crosshair!=null&&opts.crosshair>=0&&opts.crosshair<refData.length){
    const cx=toX(opts.crosshair);
    ctx.strokeStyle='rgba(42,74,127,.5)';ctx.lineWidth=1;ctx.setLineDash([]);
    ctx.beginPath();ctx.moveTo(cx,pad.t);ctx.lineTo(cx,pad.t+ch);ctx.stroke();
    if(mode==='pe'||mode==='combined'){
      const dp=peData[Math.min(opts.crosshair,peData.length-1)];
      if(dp&&dp.y!=null){const cy=toY(Math.max(yMin,Math.min(yMax,dp.y)));ctx.beginPath();ctx.arc(cx,cy,3.5,0,Math.PI*2);ctx.fillStyle='#3d6baf';ctx.fill();}
    }
    if(mode==='pb'||mode==='combined'){
      const dp=pbData[Math.min(opts.crosshair,pbData.length-1)];
      if(dp&&dp.y!=null){const cy=toY(Math.max(yMin,Math.min(yMax,dp.y)));ctx.beginPath();ctx.arc(cx,cy,3.5,0,Math.PI*2);ctx.fillStyle='#2a7a4f';ctx.fill();}
    }
    if(mode==='combined'){
      const dp=activeData[Math.min(opts.crosshair,activeData.length-1)];
      if(dp&&dp.y!=null){const cy=toY(Math.max(yMin,Math.min(yMax,dp.y)));ctx.beginPath();ctx.arc(cx,cy,4,0,Math.PI*2);ctx.fillStyle='#7c3aed';ctx.fill();}
    }
  }
}

