function getZData(ticker, metric) {
  const t = ticker||zTicker;
  const m = metric||zMetric;
  const raw = HISTORICAL[t]||[];
  const fi = m==='pe'?2:4;
  const vals = raw.map(r=>[r[0],r[fi]]).filter(r=>r[1]!=null&&r[1]>0);
  const W = zWindow||vals.length;
  const res=[];
  for(let i=0;i<vals.length;i++){
    const start=Math.max(0,i-W+1);
    const wv=vals.slice(start,i+1).map(r=>r[1]);
    if(wv.length<4){res.push({d:vals[i][0],v:vals[i][1],z:null,m:null,s:null});continue;}

    let mean, std, zVal;
    if(zLogMode) {
      // Log-space z-score: compresses large spikes, normalises skewed distributions
      const logWv = wv.map(x => Math.log(x));
      const logVal = Math.log(vals[i][1]);
      const logMean = logWv.reduce((a,b)=>a+b)/logWv.length;
      const logVar = logWv.reduce((a,b)=>a+(b-logMean)**2,0)/(logWv.length-1);
      const logStd = Math.sqrt(logVar);
      // Back-transform mean to original space for display
      mean = Math.exp(logMean + logVar/2); // log-normal mean
      std = mean * Math.sqrt(Math.exp(logVar)-1); // log-normal std in original space
      zVal = logStd > 0 ? (logVal - logMean) / logStd : 0;
    } else {
      mean = wv.reduce((a,b)=>a+b)/wv.length;
      const s2 = wv.reduce((a,b)=>a+(b-mean)**2,0)/(wv.length-1);
      std = Math.sqrt(s2);
      zVal = std > 0 ? (vals[i][1]-mean)/std : 0;
    }

    res.push({d:vals[i][0],v:vals[i][1],z:zVal,m:mean,s:std});
  }
  const now=new Date('2026-03-06');
  let cutoff;
  if(zRange && zRange.startsWith('Y:')) {
    cutoff = new Date(parseInt(zRange.slice(2)), 0, 1);
  } else {
    const days={['1Y']:365.25,['2Y']:2*365.25,['5Y']:5*365.25,['10Y']:10*365.25,['All']:99999}[zRange]||99999;
    cutoff = new Date(now.getTime() - days*86400000);
  }
  let filtered = res.filter(r=>new Date(r.d)>=cutoff);
  // Apply zoom range if active (overrides range buttons)
  if (_zZoomStart && _zZoomEnd) {
    filtered = filtered.filter(r => r.d >= _zZoomStart && r.d <= _zZoomEnd);
  }
  return filtered;
}

function zPercentile(data) {
  if(!data.length) return null;
  const last=data[data.length-1]; if(last.z==null) return null;
  const zVals=data.map(d=>d.z).filter(v=>v!=null);
  return zVals.length>1?Math.round(zVals.filter(v=>v<=last.z).length/zVals.length*100):null;
}

function renderZStatsBar(peData, pbData) {
