function _initWorldMap() {
  const container = document.getElementById('wm-body');
  const svg = document.getElementById('world-map-svg');
  if (!container || !svg) return;

  const W = container.clientWidth || 900;
  const H = container.clientHeight || 520;

  _wmSvgEl = svg;
  svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
  svg.style.height = H + 'px';

  // Background ocean
  const bg = document.createElementNS('http://www.w3.org/2000/svg','rect');
  bg.setAttribute('width', W); bg.setAttribute('height', H);
  bg.setAttribute('fill', '#0a1628');
  svg.appendChild(bg);

  // Main group for zoom/pan
  const g = document.createElementNS('http://www.w3.org/2000/svg','g');
  g.id = 'wm-g';
  svg.appendChild(g);
  _wmG = g;

  // Set up D3 projection
  _wmProjection = d3.geoNaturalEarth1()
    .scale(W / 6.3)
    .translate([W / 2, H / 2]);
  _wmPath = d3.geoPath().projection(_wmProjection);

  // Zoom behaviour
  _wmZoomBehavior = d3.zoom()
    .scaleExtent([0.8, 8])
    .on('zoom', (event) => {
      g.setAttribute('transform', event.transform.toString());
    });
  d3.select(svg).call(_wmZoomBehavior);

  // Fetch world topo
  fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json')
    .then(r => r.json())
    .then(world => {
      _wmTopo = world;
      _wmTopoLoaded = true;
      const countries = topojson.feature(world, world.objects.countries);
      const borders   = topojson.mesh(world, world.objects.countries, (a,b) => a !== b);

      // Draw country paths
      countries.features.forEach(feat => {
        const iso3 = _numericToIso3(feat.id);
        const name  = ISO3_MAP[iso3] || null;
        const cData = name ? COUNTRIES.find(c => c.name === name) : null;

        const path = document.createElementNS('http://www.w3.org/2000/svg','path');
        path.setAttribute('d', _wmPath(feat) || '');
        path.setAttribute('class', 'wm-country' + (cData ? '' : ' wm-no-data'));
        path.setAttribute('data-iso3', iso3 || '');
        path.setAttribute('data-name', name || '');

        if (cData) {
          path.addEventListener('mouseenter', (e) => _wmShowInfo(e, cData));
          path.addEventListener('mouseleave', _wmHideInfo);
          path.addEventListener('click', () => {
            // Jump to Z-Score tab for this country
            const nb = document.querySelectorAll('.nb');
            nb.forEach(b => b.classList.remove('active'));
            const zsBtn = [...nb].find(b => b.textContent.trim()==='Z-Score Charts');
            if (zsBtn) zsBtn.classList.add('active');
            document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
            document.getElementById('tab-zscore').classList.add('active');
            zTicker = cData.bloomberg;
            renderZScore();
          });
          path.style.cursor = 'pointer';
        }
        g.appendChild(path);
      });

      // Border lines
      const borderPath = document.createElementNS('http://www.w3.org/2000/svg','path');
      borderPath.setAttribute('d', _wmPath(borders) || '');
      borderPath.setAttribute('fill', 'none');
      borderPath.setAttribute('stroke', '#0d1f35');
      borderPath.setAttribute('stroke-width', '0.3');
      borderPath.setAttribute('pointer-events', 'none');
      g.appendChild(borderPath);

      _wmColorCountries();
    })
    .catch(() => {
      // Fallback message if CDN fails
      const text = document.createElementNS('http://www.w3.org/2000/svg','text');
      text.setAttribute('x', W/2); text.setAttribute('y', H/2);
      text.setAttribute('text-anchor','middle');
      text.setAttribute('fill','var(--text3)'); text.setAttribute('font-size','13');
      text.textContent = 'Map requires internet connection to load TopoJSON data';
      g.appendChild(text);
    });
}

