  return `<span class="badge ${m[cls]||'badge-agg'}">${cls}</span>`;
}

// heatmap color: green=cheap, red=expensive — academic ink palette
function heatCol(z_like, scale=1) {
  const v = Math.max(-1,Math.min(1, (z_like||0)*scale));
  if (v > 0) {
    const t = v;
    // neutral sand → scholarly crimson
    return `rgb(${Math.round(168+60*t)},${Math.round(100-68*t)},${Math.round(70-38*t)})`;
  } else {
    const t = Math.abs(v);
    // neutral sand → forest green
    return `rgb(${Math.round(168-138*t)},${Math.round(100+40*t)},${Math.round(70+10*t)})`;
  }
}

// normalize raw PE/PB to z-like value for heatmap
function toHeatZ(c, metric, hmZMode) {
  if (metric === 'pe_z') return hmZMode==='classification' ? (c.pe_z_cls||c.pe_z) : c.pe_z;
  if (metric === 'pb_z') return hmZMode==='classification' ? (c.pb_z_cls||c.pb_z) : c.pb_z;
  if (metric === 'pe')   return c.pe ? (c.pe - STATS.mean_pe) / STATS.std_pe : null;
  if (metric === 'best_pe') return c.best_pe ? (c.best_pe - STATS.mean_pe) / STATS.std_pe : null;
  return null;
}

// active z value depending on mode
function activeZ(c, mode, field='pe') {
  if (mode==='classification') return field==='pe' ? c.pe_z_cls : c.pb_z_cls;
  return field==='pe' ? c.pe_z : c.pb_z;
}

