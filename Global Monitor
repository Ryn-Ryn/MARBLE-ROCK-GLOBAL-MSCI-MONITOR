function _attachZHover() {
  const version=++_zHoverVersion;
  ['z-main','z-pb','z-osc'].forEach(id=>{
    const canvas=document.getElementById(id); if(!canvas) return;
    canvas.onmousemove=e=>{
      if(version!==_zHoverVersion) return;
      const rect=canvas.getBoundingClientRect();
      const pct=(e.clientX-rect.left)/rect.width;
      const len=Math.max(_zData.length,_zDataPb.length,1);
      const idx=Math.max(0,Math.min(len-1,Math.round(pct*(len-1))));
      if(idx===_zCrosshairIdx) return;
      _zCrosshairIdx=idx;
      if(!_zRafPending){_zRafPending=true;requestAnimationFrame(()=>{_zRafPending=false;_renderZCharts();});}
      const dPe=_zData[Math.min(idx,_zData.length-1)];
      const dPb=_zDataPb[Math.min(idx,_zDataPb.length-1)];
      if(!dPe) return;
      const peZStr=dPe.z!=null?(dPe.z>=0?'+':'')+dPe.z.toFixed(2)+'σ':'–';
      const pbZStr=dPb&&dPb.z!=null?(dPb.z>=0?'+':'')+dPb.z.toFixed(2)+'σ':'–';
      const signal=z=>z==null?'–':z<-2?'Deeply cheap':z<-1?'Cheap':z<0?'Mildly cheap':z<1?'Mildly exp.':z<2?'Expensive':'Deeply exp.';
      document.getElementById('z-readout').innerHTML=`
        <div class="cr-item"><span class="cr-lbl">Date</span><span class="cr-val">${dPe.d}</span></div>
        <div class="cr-item"><span class="cr-lbl">PE</span><span class="cr-val">${dPe.v!=null?dPe.v.toFixed(1)+'x':'–'}</span></div>
        <div class="cr-item"><span class="cr-lbl">PE Z</span><span class="cr-val" style="color:${dPe.z!=null?zColor(dPe.z):'var(--text3)'}">${peZStr}</span></div>
        <div class="cr-item"><span class="cr-lbl">Signal</span><span class="cr-val" style="color:${dPe.z!=null?zColor(dPe.z):'var(--text3)'}">${signal(dPe.z)}</span></div>
        <div class="cr-item"><span class="cr-lbl">P/B Z</span><span class="cr-val" style="color:${dPb&&dPb.z!=null?zColor(dPb.z):'var(--text3)'}">${pbZStr}</span></div>
        <div class="cr-item"><span class="cr-lbl">Mean±1σ</span><span class="cr-val">${dPe.m!=null?dPe.m.toFixed(1)+'±'+dPe.s?.toFixed(1):'–'}</span></div>`;
      document.getElementById('osc-readout').innerHTML=(()=>{
        if(_oscMode==='pe') return `<div class="cr-item"><span class="cr-lbl">PE Z</span><span class="cr-val" style="color:${dPe.z!=null?zColor(dPe.z):'var(--text3)'};font-weight:700">${peZStr}</span></div>`;
        if(_oscMode==='pb') return `<div class="cr-item"><span class="cr-lbl">P/B Z</span><span class="cr-val" style="color:${dPb&&dPb.z!=null?zColor(dPb.z):'var(--text3)'};font-weight:700">${pbZStr}</span></div>`;
        const pw=_oscPeWeight/100, bw=1-pw;
        const combZ=(dPe.z!=null&&dPb&&dPb.z!=null)?(dPe.z*pw+dPb.z*bw):null;
        const combStr=combZ!=null?(combZ>=0?'+':'')+combZ.toFixed(2)+'σ':'–';
        return `<div class="cr-item"><span class="cr-lbl">Combined Z</span><span class="cr-val" style="color:${combZ!=null?zColor(combZ):'var(--text3)'};font-weight:700">${combStr}</span></div>
                <div class="cr-item"><span class="cr-lbl">PE Z</span><span class="cr-val" style="color:${dPe.z!=null?zColor(dPe.z):'var(--text3)'}">${peZStr}</span></div>
                <div class="cr-item"><span class="cr-lbl">P/B Z</span><span class="cr-val" style="color:${dPb&&dPb.z!=null?zColor(dPb.z):'var(--text3)'}">${pbZStr}</span></div>`;
      })();
      const pbRo=document.getElementById('z-pb-readout');
      if(pbRo&&dPb) pbRo.innerHTML=`
        <div class="cr-item"><span class="cr-lbl">P/B</span><span class="cr-val">${dPb.v!=null?dPb.v.toFixed(2)+'x':'–'}</span></div>
        <div class="cr-item"><span class="cr-lbl">P/B Z</span><span class="cr-val" style="color:${dPb.z!=null?zColor(dPb.z):'var(--text3)'}">${pbZStr}</span></div>
