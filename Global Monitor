let qScatterZMode = 'universe';
let qScatterCls = 'all';

function setQScatterCls(cls, btn) {
  qScatterCls = cls;
  document.querySelectorAll('[data-qscls]').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawZZScatter();
}
function setQScatterZMode(mode, btn) {
