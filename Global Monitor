function _pdGetPxData() {
  if (!_pdTicker || !PRICE_DATA[_pdTicker]) return [];
  const all = PRICE_DATA[_pdTicker]; // [[date, px], ...]
  if (_pdPxRange === 'All') return all;
  const cutoff = new Date();
  const yrs = parseInt(_pdPxRange);
  cutoff.setFullYear(cutoff.getFullYear() - yrs);
  const cut = cutoff.toISOString().slice(0,10);
  return all.filter(r => r[0] >= cut);
}

