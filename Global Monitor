// OPTIMIZER
// ══════════════════════════════════════════════════════════
let optModel = 'mr', optStyle = 'topn', retSortKey = 'mr', retSortAsc = false;

function setOptModel(m,btn){ optModel=m; document.querySelectorAll('[data-om]').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); runOptimizer(); }
function setOptStyle(s,btn){
  optStyle=s;
  document.querySelectorAll('[data-os]').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('topn-row').style.display = s==='topn'?'flex':'none';
  document.getElementById('ra-row').style.display   = s==='mv'  ?'flex':'none';
  runOptimizer();
}
function sortRetTable(k){ if(retSortKey===k) retSortAsc=!retSortAsc; else{retSortKey=k;retSortAsc=false;} runOptimizer(); }

function runOptimizer() {
  const rets = calcExpectedReturns();
  const clsF = document.getElementById('opt-cls-filter').value;
  const maxW  = +document.getElementById('opt-maxw').value / 100;
  const topN  = +document.getElementById('opt-topn').value;
  const ra    = +document.getElementById('opt-ra').value;

  // Filter by classification
  let universe = clsF==='all' ? rets : rets.filter(r=>r.cls===clsF);
  if(!universe.length) return;

  const retField = optModel; // 'mr'|'ey'|'comb'

  // ── OPTIMIZER ──────────────────────────────────────────
  // Risk proxy: use |PE_z| as vol proxy (higher z = more deviation from mean = higher risk)
  const vol = r => { const base = r.cls==='Developed'?0.15:r.cls==='Emerging'?0.22:r.cls==='Frontier'?0.28:0.18; return Math.max(0.08, base + Math.abs(r.pe_z||0)*0.025); };

  let weights = {};

  if(optStyle==='topn') {
    const sorted = [...universe].sort((a,b)=>b[retField]-a[retField]);
    const top = sorted.slice(0, topN);
    const raw = top.reduce((s,r)=>s+Math.max(0,r[retField]),0);
    top.forEach(r=>{
      weights[r.bloomberg] = raw>0 ? Math.min(maxW, Math.max(0,r[retField])/raw) : 1/top.length;
    });
    // Normalise (cap at maxW, renorm)
    weights = normaliseWeights(weights, maxW);
  }
  else if(optStyle==='mv') {
    // Markowitz: w ∝ μ/σ² − λ*σ² (diagonal covariance)
    // w_i ∝ (μ_i/σ_i² - 0) / (2*λ*σ_i²) → simplifies to μ_i / (λ * σ_i^2)
    universe.forEach(r=>{
      const s = vol(r);
      const w = Math.max(0, r[retField]) / (ra * s * s);
      weights[r.bloomberg] = w;
    });
    weights = normaliseWeights(weights, maxW);
  }
  else if(optStyle==='rp') {
    // Risk parity: w_i ∝ 1/σ_i
    universe.forEach(r=>{ weights[r.bloomberg] = 1/vol(r); });
    weights = normaliseWeights(weights, maxW);
  }

  // Equal-weight benchmark (all universe)
  const ewW = {};
  universe.forEach(r=>{ ewW[r.bloomberg] = 1/universe.length; });

  // ── PORTFOLIO STATS ─────────────────────────────────────
  const RHO_OPT = 0.50; // constant cross-market correlation
  function pfStats(wts) {
    const entries = Object.entries(wts).filter(([,w])=>w>0.001);
    const er = entries.reduce((s,[id,w])=>{ const r=rets.find(x=>x.bloomberg===id); return s+(r?r[retField]*w:0); },0);
    let wSigSum=0, wSigSqSum=0;
    entries.forEach(([id,w])=>{ const r=rets.find(x=>x.bloomberg===id); if(!r) return; const v=vol(r); wSigSum+=w*v; wSigSqSum+=w*w*v*v; });
    const rv = RHO_OPT*wSigSum*wSigSum + (1-RHO_OPT)*wSigSqSum;
    const rv_sd = Math.sqrt(rv)*100;
    const sharpe = rv_sd>0 ? er/rv_sd : 0;
    const n = entries.length;
    return { er: Math.round(er*10)/10, sd: Math.round(rv_sd*10)/10, sharpe: Math.round(sharpe*100)/100, n };
  }

  const optStats = pfStats(weights);
  const ewStats  = pfStats(ewW);
  // "Benchmark": top-1 (concentrated, undiversified)
  const top1 = [...universe].sort((a,b)=>b[retField]-a[retField])[0];
  const t1W = top1 ? {[top1.bloomberg]:1} : {};
  const t1Stats = pfStats(t1W);

  // ── RENDER COMPARISON CARDS ──────────────────────────────
  document.getElementById('pf-compare-cards').innerHTML = `
    <div class="pf-card" style="border-top:2px solid var(--accent)">
      <div class="pf-card-lbl">Optimized Portfolio</div>
      <div class="pf-card-val" style="color:var(--accent2)">${optStats.er.toFixed(1)}%</div>
      <div class="pf-card-sub">Expected return (${retField.toUpperCase()})</div>
      <div class="pf-card-sub">σ ${optStats.sd.toFixed(1)}% · Sharpe ~${optStats.sharpe.toFixed(2)} · ${optStats.n} holdings</div>
    </div>
    <div class="pf-card" style="border-top:2px solid var(--text3)">
      <div class="pf-card-lbl">Equal-Weight (${universe.length} mkts)</div>
      <div class="pf-card-val" style="color:var(--text2)">${ewStats.er.toFixed(1)}%</div>
      <div class="pf-card-sub">Expected return (${retField.toUpperCase()})</div>
      <div class="pf-card-sub">σ ${ewStats.sd.toFixed(1)}% · Sharpe ~${ewStats.sharpe.toFixed(2)} · ${ewStats.n} holdings</div>
    </div>
    <div class="pf-card" style="border-top:2px solid var(--gold)">
      <div class="pf-card-lbl">Opt vs Equal-Weight</div>
      <div class="pf-card-val" style="color:${optStats.er>=ewStats.er?'var(--green2)':'var(--red2)'}">${optStats.er>=ewStats.er?'+':''}${(optStats.er-ewStats.er).toFixed(1)}%</div>
      <div class="pf-card-sub">Return advantage</div>
      <div class="pf-card-sub">Sharpe Δ ${optStats.sharpe>=ewStats.sharpe?'+':''}${(optStats.sharpe-ewStats.sharpe).toFixed(2)}</div>
    </div>`;

  // ── WEIGHT CHARTS ────────────────────────────────────────
  function renderWeightChart(containerId, wts, color) {
    const entries = Object.entries(wts).filter(([,w])=>w>0.001)
      .sort((a,b)=>b[1]-a[1]).slice(0,15);
    const el = document.getElementById(containerId);
    if(!el) return;
    el.innerHTML = entries.map(([id,w])=>{
      const c = COUNTRIES.find(x=>x.bloomberg===id);
      return `<div class="wgt-row">
        <span class="wgt-name" title="${c?.name||id}">${flag(c?.name||'')} ${c?.name||id}</span>
        <div class="wgt-bar-outer"><div class="wgt-fill" style="width:${Math.round(w*100)}%;background:${color}"></div></div>
        <span class="wgt-pct">${(w*100).toFixed(1)}%</span>
      </div>`;
    }).join('');
  }
  renderWeightChart('opt-weights-chart', weights, 'var(--accent)');
  renderWeightChart('ew-weights-chart',  ewW,     'var(--text3)');

  // ── EFFICIENT FRONTIER ───────────────────────────────────
  updateEfficientFrontier(universe, weights, ewW, retField);

  // ── EXPECTED RETURNS TABLE ────────────────────────────────
  // Sort
  const sortedRets = [...universe].sort((a,b)=>{
    const av = retSortKey==='name'?a.name:retSortKey==='cls'?a.cls:a[retSortKey]??-999;
    const bv = retSortKey==='name'?b.name:retSortKey==='cls'?b.cls:b[retSortKey]??-999;
    if(typeof av==='string') return retSortAsc?av.localeCompare(bv):bv.localeCompare(av);
    return retSortAsc?av-bv:bv-av;
  });

  const maxMR   = Math.max(...universe.map(r=>r.mr));
  const maxEY   = Math.max(...universe.map(r=>r.ey));
  const maxComb = Math.max(...universe.map(r=>r.comb));

  document.getElementById('ret-tbody').innerHTML = sortedRets.map(r=>{
    const w = weights[r.bloomberg]||0;
    const mrCol  = r.mr   > 12 ? 'var(--green2)' : r.mr   < 3 ? 'var(--red2)' : 'var(--text2)';
    const eyCol  = r.ey   > 12 ? 'var(--green2)' : r.ey   < 3 ? 'var(--red2)' : 'var(--text2)';
    const combCol= r.comb > 12 ? 'var(--green2)' : r.comb < 3 ? 'var(--red2)' : 'var(--text2)';
    const wCol   = w > 0.1 ? 'var(--accent2)' : w > 0 ? 'var(--text2)' : 'var(--text3)';
    return `<tr>
      <td><div style="display:flex;align-items:center;gap:6px;">${flag(r.name)}<span style="color:var(--text);font-weight:500">${r.name}</span></div></td>
      <td>${clsBadge(r.cls)}</td>
      <td style="font-family:'Space Mono',monospace">${r.pe.toFixed(1)}x</td>
      <td style="font-family:'Space Mono',monospace;color:${zColor(r.pe_z)}">${zLabel(r.pe_z)}</td>
      <td>
        <span style="font-family:'Space Mono',monospace;color:${mrCol};font-weight:600;margin-right:6px">${r.mr.toFixed(1)}%</span>
        <span class="ret-bar"><span class="ret-bar-fill" style="width:${Math.max(0,r.mr/maxMR*100).toFixed(0)}%;background:${mrCol}"></span></span>
      </td>
      <td>
        <span style="font-family:'Space Mono',monospace;color:${eyCol};font-weight:600;margin-right:6px">${r.ey.toFixed(1)}%</span>
        <span class="ret-bar"><span class="ret-bar-fill" style="width:${Math.max(0,r.ey/maxEY*100).toFixed(0)}%;background:${eyCol}"></span></span>
      </td>
      <td>
        <span style="font-family:'Space Mono',monospace;color:${combCol};font-weight:600;margin-right:6px">${r.comb.toFixed(1)}%</span>
        <span class="ret-bar"><span class="ret-bar-fill" style="width:${Math.max(0,r.comb/maxComb*100).toFixed(0)}%;background:${combCol}"></span></span>
      </td>
      <td style="font-family:'Space Mono',monospace;color:${wCol};font-weight:${w>0?700:400}">${w>0?(w*100).toFixed(1)+'%':'–'}</td>
    </tr>`;
  }).join('');
}

function normaliseWeights(raw, maxW) {
  // Iterative cap-and-renorm
  let wts = {...raw};
  for(let iter=0;iter<20;iter++){
    const tot = Object.values(wts).reduce((s,w)=>s+w,0);
    if(tot<=0) break;
    Object.keys(wts).forEach(k=>wts[k]/=tot);
    let changed=false;
    Object.keys(wts).forEach(k=>{ if(wts[k]>maxW){wts[k]=maxW;changed=true;} });
    if(!changed) break;
  }
  const tot2 = Object.values(wts).reduce((s,w)=>s+w,0);
  if(tot2>0) Object.keys(wts).forEach(k=>wts[k]/=tot2);
  return wts;
}



// ══════════════════════════════════════════════════════════
// EFFICIENT FRONTIER
// ══════════════════════════════════════════════════════════
let efModel = 'mr';   // which return model to use for frontier
let efPoints = 80;    // number of λ sweep points
let _efUniverse = []; // last computed universe (from runOptimizer)
let _efFrontier = []; // [{er, sd, sharpe, weights, λ}]
let _efOptPoint = null;
let _efEwPoint  = null;
let _efHoverIdx = -1;

function setEfModel(m, btn) {
  efModel = m;
  document.querySelectorAll('[data-efm]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  _rebuildFrontier();
}
function setEfPoints(n, btn) {
  efPoints = n;
  document.querySelectorAll('[data-efp]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  _rebuildFrontier();
}

// Called from runOptimizer to feed universe + current portfolio point
function updateEfficientFrontier(universe, optWeights, ewWeights, retField) {
  _efUniverse = universe;
  _efOptPoint = _efPfStats(optWeights, universe, retField);
  _efEwPoint  = _efPfStats(ewWeights,  universe, retField);
  efModel = retField; // sync model button
  document.querySelectorAll('[data-efm]').forEach(b => {
    b.classList.toggle('active', b.getAttribute('onclick')?.includes(`'${retField}'`));
  });
  _rebuildFrontier();
}

function _rebuildFrontier() {
  if (!_efUniverse.length) return;
  const maxW = +document.getElementById('opt-maxw').value / 100;
  _efFrontier = _computeFrontier(_efUniverse, efModel, maxW, efPoints);
  // Recompute current opt/ew points using efModel
  const optWeights = _efCurrentWeights(_efUniverse, efModel, maxW);
  _efOptPoint = _efPfStats(optWeights, _efUniverse, efModel);

  const ewW = {};
  _efUniverse.forEach(r => { ewW[r.bloomberg] = 1 / _efUniverse.length; });
  _efEwPoint = _efPfStats(ewW, _efUniverse, efModel);
  _efHoverIdx = -1;
  setTimeout(() => { _drawEfficientFrontier(); _attachEfHover(); }, 30);
}

// Recompute optimized weights for given model (mirrors runOptimizer logic)
function _efCurrentWeights(universe, retField, maxW) {
  const style = optStyle;
  const ra    = +document.getElementById('opt-ra').value;
  const topN  = +document.getElementById('opt-topn').value;
  const vol   = r => { const base = r.cls==='Developed'?0.15:r.cls==='Emerging'?0.22:r.cls==='Frontier'?0.28:0.18; return Math.max(0.08, base + Math.abs(r.pe_z||0)*0.025); };
  let weights = {};
  if (style === 'topn') {
    const sorted = [...universe].sort((a, b) => b[retField] - a[retField]);
    const top = sorted.slice(0, topN);
    const raw = top.reduce((s, r) => s + Math.max(0, r[retField]), 0);
    top.forEach(r => { weights[r.bloomberg] = raw > 0 ? Math.min(maxW, Math.max(0, r[retField]) / raw) : 1 / top.length; });
  } else if (style === 'mv') {
    universe.forEach(r => { const s = vol(r); weights[r.bloomberg] = Math.max(0, r[retField]) / (ra * s * s); });
  } else if (style === 'rp') {
    universe.forEach(r => { weights[r.bloomberg] = 1 / vol(r); });
  }
  return normaliseWeights(weights, maxW);
}

function _efPfStats(wts, universe, retField) {
  const vol = r => { const base = r.cls==='Developed'?0.15:r.cls==='Emerging'?0.22:r.cls==='Frontier'?0.28:0.18; return Math.max(0.08, base + Math.abs(r.pe_z||0)*0.025); };
  const RHO = 0.50; // constant cross-market correlation (realistic for global equities)
  const entries = Object.entries(wts).filter(([, w]) => w > 0.001);
  if (!entries.length) return null;
  const er = entries.reduce((s, [id, w]) => {
    const r = universe.find(x => x.bloomberg === id); return s + (r ? r[retField] * w : 0);
  }, 0);
  // Constant-correlation variance: Var = ρ·(Σ w·σ)² + (1-ρ)·Σ w²·σ²
  let wSigSum = 0, wSigSqSum = 0;
  entries.forEach(([id, w]) => {
    const r = universe.find(x => x.bloomberg === id); if (!r) return;
    const v = vol(r);
    wSigSum   += w * v;
    wSigSqSum += w * w * v * v;
  });
  const rv = RHO * wSigSum * wSigSum + (1 - RHO) * wSigSqSum;
  const sd = Math.sqrt(rv) * 100;
  const sharpe = sd > 0 ? er / sd : 0;
  const holdings = entries.filter(([, w]) => w > 0.005)
    .sort((a, b) => b[1] - a[1]).slice(0, 5)
    .map(([id, w]) => { const c = COUNTRIES.find(x => x.bloomberg === id); return `${flag(c?.name || '')} ${c?.name || id} ${(w * 100).toFixed(1)}%`; });
  return { er, sd, sharpe, n: entries.length, holdings, wts };
}

function _computeFrontier(universe, retField, maxW, nPoints) {
  const vol = r => { const base = r.cls==='Developed'?0.15:r.cls==='Emerging'?0.22:r.cls==='Frontier'?0.28:0.18; return Math.max(0.08, base + Math.abs(r.pe_z||0)*0.025); };
  // Sweep λ from very large (min-variance) to very small (max-return)
  // Using log-scale for denser coverage of interesting range
  const lambdas = Array.from({ length: nPoints }, (_, i) => {
    const t = i / (nPoints - 1);
    return Math.exp(Math.log(200) * (1 - t) + Math.log(0.05) * t);
  });

  const seen = new Set();
  const frontier = [];

  lambdas.forEach(lambda => {
    // MV weights: w_i ∝ max(0, μ_i) / (λ * σ_i²)
    let rawW = {};
    universe.forEach(r => {
      const s = vol(r);
      rawW[r.bloomberg] = Math.max(0, r[retField]) / (lambda * s * s);
    });
    const wts = normaliseWeights(rawW, maxW);
    const stats = _efPfStats(wts, universe, retField);
    if (!stats) return;
    // Deduplicate near-identical points (rounded to 1dp)
    const key = `${stats.er.toFixed(1)}_${stats.sd.toFixed(1)}`;
    if (seen.has(key)) return;
    seen.add(key);
    frontier.push({ ...stats, lambda, wts });
  });

  // Sort by sd ascending to get proper frontier shape
  frontier.sort((a, b) => a.sd - b.sd);

  // Keep only Pareto-optimal points (max er for each sd level)
  const pareto = [];
  let maxEr = -Infinity;
  for (let i = frontier.length - 1; i >= 0; i--) {
    if (frontier[i].er > maxEr) { maxEr = frontier[i].er; pareto.unshift(frontier[i]); }
  }
  return pareto.length > 2 ? pareto : frontier;
}

function _efAxisParams(F) {
  if (!F || !F.length) return { sdMin:0, sdMax:30, erMin:0, erMax:20 };
  // Include off-curve benchmark points in axis range
  const allPts = [...F];
  if (_efEwPoint)  allPts.push(_efEwPoint);
  if (_efOptPoint) allPts.push(_efOptPoint);
  const allSd = allPts.map(p=>p.sd).filter(v=>isFinite(v)&&v>0);
  const allEr = allPts.map(p=>p.er).filter(isFinite);
  if (!allSd.length || !allEr.length) return { sdMin:0, sdMax:30, erMin:0, erMax:20 };
  const s0=Math.min(...allSd), s1=Math.max(...allSd);
  const e0=Math.min(...allEr), e1=Math.max(...allEr);
  const sRange = Math.max(s1-s0, 3);
  const eRange = Math.max(e1-e0, 3);
  const sp = sRange*0.12, ep = eRange*0.15;
  return {
    sdMin: Math.max(0, s0-sp), sdMax: s0+sRange+sp,
    erMin: e0-ep,              erMax: e0+eRange+ep*2,
  };
}

function _drawEfficientFrontier() {
  const canvas = document.getElementById('ef-canvas');
  const wrap   = document.getElementById('ef-chart-wrap');
  if (!canvas || !wrap || !_efFrontier.length) return;

  const dpr  = window.devicePixelRatio || 1;
  const cssW = wrap.clientWidth  || 700;
  const cssH = wrap.clientHeight || 460;
  canvas.style.width  = cssW + 'px';
  canvas.style.height = cssH + 'px';
  canvas.width  = Math.round(cssW * dpr);
  canvas.height = Math.round(cssH * dpr);

  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, cssW, cssH);

  const pad = { t:20, r:24, b:44, l:54 };
  const cw  = cssW - pad.l - pad.r;
  const ch  = cssH - pad.t - pad.b;
  const F   = _efFrontier;
  const ax  = _efAxisParams(F);
  const { sdMin, sdMax, erMin, erMax } = ax;

  const toX = v => pad.l + (v-sdMin)/(sdMax-sdMin)*cw;
  const toY = v => pad.t + (1-(v-erMin)/(erMax-erMin))*ch;

  // ── Key waypoints ──────────────────────────────────────
  const minVarP    = F.reduce((b,p) => p.sd<b.sd ? p:b, F[0]);
  const maxRetP    = F.reduce((b,p) => p.er>b.er ? p:b, F[0]);
  const maxSharpeP = F.reduce((b,p) => p.sharpe>b.sharpe ? p:b, F[0]);
  const consP      = F[Math.floor(F.length*0.20)];
  const balP       = F[Math.floor(F.length*0.50)];
  const aggP       = F[Math.floor(F.length*0.78)];

  // ── Nice grid ─────────────────────────────────────────
  function niceStep(range, n) {
    if (!range || !isFinite(range) || range <= 0) return 1;
    const raw=range/n, mag=Math.pow(10,Math.floor(Math.log10(raw)));
    return [1,2,2.5,5,10].map(f=>f*mag).find(f=>range/f<=n+1)||mag;
  }
  const xStep = niceStep(sdMax-sdMin, 6);
  const yStep = niceStep(erMax-erMin, 6);

  ctx.strokeStyle='rgba(180,170,155,.5)'; ctx.lineWidth=0.5; ctx.setLineDash([]);
  for(let v=Math.ceil(sdMin/xStep)*xStep; v<=sdMax+xStep*.01; v+=xStep){
    const x=toX(v); if(x<pad.l||x>pad.l+cw) continue;
    ctx.beginPath(); ctx.moveTo(x,pad.t); ctx.lineTo(x,pad.t+ch); ctx.stroke();
    ctx.fillStyle='rgba(110,100,85,.7)'; ctx.font='10px IBM Plex Mono,monospace'; ctx.textAlign='center';
    ctx.fillText(v.toFixed(1)+'%', x, pad.t+ch+14);
  }
  for(let v=Math.ceil(erMin/yStep)*yStep; v<=erMax+yStep*.01; v+=yStep){
    const y=toY(v); if(y<pad.t||y>pad.t+ch) continue;
    ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(pad.l+cw,y); ctx.stroke();
    ctx.fillStyle='rgba(110,100,85,.7)'; ctx.font='10px IBM Plex Mono,monospace'; ctx.textAlign='right';
    ctx.fillText(v.toFixed(1)+'%', pad.l-6, y+3.5);
  }

  // Axis labels
  ctx.fillStyle='rgba(90,105,125,.85)'; ctx.font='11px Inter,sans-serif'; ctx.textAlign='center';
  ctx.fillText('Portfolio Risk  σ (% p.a.)', pad.l+cw/2, cssH-4);
  ctx.save(); ctx.translate(12, pad.t+ch/2); ctx.rotate(-Math.PI/2);
  ctx.fillText('Expected Return (% p.a.)', 0, 0); ctx.restore();

  // Plot border
  ctx.strokeStyle='rgba(180,170,155,.6)'; ctx.lineWidth=1;
  ctx.strokeRect(pad.l, pad.t, cw, ch);

  // ── Capital Market Line ────────────────────────────────
  if(maxSharpeP.sd !== minVarP.sd){
    const sl=(maxSharpeP.er-minVarP.er)/(maxSharpeP.sd-minVarP.sd);
    const cmlY0=minVarP.er+sl*(sdMin-minVarP.sd);
    const cmlY1=minVarP.er+sl*(sdMax-minVarP.sd);
    ctx.setLineDash([5,5]); ctx.strokeStyle='rgba(42,74,127,.28)'; ctx.lineWidth=1.2;
    ctx.beginPath(); ctx.moveTo(pad.l,toY(cmlY0)); ctx.lineTo(pad.l+cw,toY(cmlY1)); ctx.stroke();
    ctx.setLineDash([]);
  }

  // ── Frontier fill ──────────────────────────────────────
  ctx.beginPath();
  F.forEach((p,i)=>{ const x=toX(p.sd),y=toY(p.er); i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
  ctx.lineTo(toX(F[F.length-1].sd), pad.t+ch);
  ctx.lineTo(toX(F[0].sd), pad.t+ch);
  ctx.closePath();
  const fg=ctx.createLinearGradient(pad.l,pad.t,pad.l,pad.t+ch);
  fg.addColorStop(0,'rgba(42,74,127,.15)'); fg.addColorStop(1,'rgba(42,74,127,.01)');
  ctx.fillStyle=fg; ctx.fill();

  // ── Frontier line ──────────────────────────────────────
  const lgX0=toX(F[0].sd), lgX1=toX(F[F.length-1].sd);
  const lg=ctx.createLinearGradient(lgX0,0, lgX1===lgX0 ? lgX0+1 : lgX1, 0);
  lg.addColorStop(0,'#1a7a45'); lg.addColorStop(.4,'#2a4a7f');
  lg.addColorStop(.75,'#7c4a1e'); lg.addColorStop(1,'#8b2020');
  ctx.strokeStyle=lg; ctx.lineWidth=3; ctx.lineJoin='round'; ctx.lineCap='round';
  ctx.beginPath();
  F.forEach((p,i)=>{ const x=toX(p.sd),y=toY(p.er); i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
  ctx.stroke();

  // ── EW benchmark (off-curve) ───────────────────────────
  if(_efEwPoint){
    const ex=toX(_efEwPoint.sd), ey=toY(_efEwPoint.er);
    // dashed vertical drop to frontier
    const nearF=F.reduce((b,p)=>Math.abs(p.sd-_efEwPoint.sd)<Math.abs(b.sd-_efEwPoint.sd)?p:b,F[0]);
    ctx.setLineDash([3,3]); ctx.strokeStyle='rgba(110,100,80,.4)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(ex,ey); ctx.lineTo(toX(nearF.sd),toY(nearF.er)); ctx.stroke();
    ctx.setLineDash([]);
    // Diamond
    ctx.beginPath(); ctx.moveTo(ex,ey-6); ctx.lineTo(ex+5,ey); ctx.lineTo(ex,ey+6); ctx.lineTo(ex-5,ey); ctx.closePath();
    ctx.fillStyle='rgba(110,100,80,.85)'; ctx.fill();
    ctx.strokeStyle='white'; ctx.lineWidth=1.5; ctx.stroke();
  }

  // ── Current portfolio ──────────────────────────────────
  if(_efOptPoint){
    const ox=toX(_efOptPoint.sd), oy=toY(_efOptPoint.er);
    ctx.beginPath(); ctx.arc(ox,oy,8,0,Math.PI*2);
    ctx.fillStyle='#7c3aed'; ctx.fill();
    ctx.strokeStyle='white'; ctx.lineWidth=2; ctx.stroke();
    ctx.fillStyle='white'; ctx.font='bold 11px sans-serif'; ctx.textAlign='center';
    ctx.fillText('▸', ox+.5, oy+4);
  }

  // ── Waypoint dots ──────────────────────────────────────
  const wpts=[
    {p:minVarP,   col:'#1a7a45', r:7},
    {p:consP,     col:'#2a6458', r:6},
    {p:balP,      col:'#2a4a7f', r:6},
    {p:aggP,      col:'#7c4a1e', r:6},
    {p:maxRetP,   col:'#8b2020', r:7},
  ];
  wpts.forEach(({p,col,r})=>{
    if(!p) return;
    ctx.beginPath(); ctx.arc(toX(p.sd),toY(p.er),r,0,Math.PI*2);
    ctx.fillStyle=col; ctx.fill();
    ctx.strokeStyle='white'; ctx.lineWidth=2; ctx.stroke();
  });

  // ── Max Sharpe: star with halo ─────────────────────────
  if(maxSharpeP){
    const mx=toX(maxSharpeP.sd), my=toY(maxSharpeP.er);
    ctx.beginPath(); ctx.arc(mx,my,14,0,Math.PI*2);
    ctx.fillStyle='rgba(42,74,127,.1)'; ctx.fill();
    ctx.strokeStyle='rgba(42,74,127,.4)'; ctx.lineWidth=1.5; ctx.stroke();
    ctx.beginPath(); ctx.arc(mx,my,9,0,Math.PI*2);
    ctx.fillStyle='#2a4a7f'; ctx.fill();
    ctx.strokeStyle='white'; ctx.lineWidth=2; ctx.stroke();
    ctx.fillStyle='white'; ctx.font='bold 12px sans-serif'; ctx.textAlign='center';
    ctx.fillText('★', mx, my+4.5);
  }

  // ── Hover crosshair ────────────────────────────────────
  if(_efHoverIdx>=0 && _efHoverIdx<F.length){
    const hp=F[_efHoverIdx];
    const hx=toX(hp.sd), hy=toY(hp.er);
    ctx.setLineDash([4,4]); ctx.strokeStyle='rgba(42,74,127,.35)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(hx,pad.t); ctx.lineTo(hx,pad.t+ch); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(pad.l,hy); ctx.lineTo(pad.l+cw,hy); ctx.stroke();
    ctx.setLineDash([]);
    ctx.beginPath(); ctx.arc(hx,hy,5,0,Math.PI*2);
    ctx.fillStyle='white'; ctx.fill();
    ctx.strokeStyle='#2a4a7f'; ctx.lineWidth=2.5; ctx.stroke();
  }

  // ── HTML overlay labels ────────────────────────────────
  _renderEfLabels({pad, toX, toY, cssW, cssH,
    minVarP, consP, balP, aggP, maxRetP, maxSharpeP});
}

function _renderEfLabels({pad, toX, toY, cssW, cssH, minVarP, consP, balP, aggP, maxRetP, maxSharpeP}) {
  const el = document.getElementById('ef-labels');
  if (!el) return;

  // Each label: dot position → leader line → pill label
  // We position labels so they never overlap: alternate above/below the curve
  const pts = [
    { p:minVarP,    col:'#1a7a45', name:'Min Variance',  side:'above', offset:{x:-30,y:-38} },
    { p:consP,      col:'#2a6458', name:'Conservative',   side:'above', offset:{x:-20,y:-38} },
    { p:balP,       col:'#2a4a7f', name:'Balanced',        side:'below', offset:{x:8,  y:32 } },
    { p:aggP,       col:'#7c4a1e', name:'Growth',          side:'above', offset:{x:8,  y:-38} },
    { p:maxRetP,    col:'#8b2020', name:'Max Return',      side:'below', offset:{x:-30,y:32 } },
    { p:maxSharpeP, col:'#2a4a7f', name:'★ Max Sharpe',   side:'above', offset:{x:16, y:-52} },
  ];

  // Also add EW and Current
  if (_efEwPoint)  pts.push({ p:_efEwPoint,  col:'rgba(100,90,70,.9)', name:'EW Benchmark', side:'below', offset:{x:10,y:32} });
  if (_efOptPoint) pts.push({ p:_efOptPoint, col:'#7c3aed',            name:'Current',       side:'below', offset:{x:10,y:32} });

  el.innerHTML = pts.map(({p, col, name, offset}) => {
    if(!p) return '';
    const dx = toX(p.sd), dy = toY(p.er);
    // Label box top-left in absolute coords
    const lx = dx + offset.x;
    const ly = dy + offset.y;
    const sub = `${p.er.toFixed(1)}% / σ${p.sd.toFixed(1)}%`;
    const sharpe = p.sharpe ? ` · ${p.sharpe.toFixed(2)}` : '';
    return `
      <svg style="position:absolute;top:0;left:0;width:${cssW}px;height:${cssH}px;overflow:visible;pointer-events:none;" aria-hidden="true">
        <line x1="${dx}" y1="${dy}" x2="${lx+48}" y2="${ly+(offset.y<0?26:0)}"
              stroke="${col}" stroke-width="1" stroke-dasharray="3 2" opacity=".6"/>
        <circle cx="${lx+48}" cy="${ly+(offset.y<0?26:0)}" r="2" fill="${col}" opacity=".7"/>
      </svg>
      <div style="
        position:absolute;
        left:${lx}px; top:${ly}px;
        background:var(--card);
        border:1px solid ${col};
        border-left:3px solid ${col};
        border-radius:3px;
        padding:3px 7px;
        white-space:nowrap;
        box-shadow:0 1px 6px rgba(0,0,0,.12);
      ">
        <div style="font-size:9.5px;font-weight:700;color:${col};font-family:'IBM Plex Mono',monospace;letter-spacing:.2px;">${name}</div>
        <div style="font-size:8.5px;color:var(--text3);font-family:'IBM Plex Mono',monospace;margin-top:1px;">${sub}${sharpe}</div>
      </div>`;
  }).join('');
}

function _attachEfHover() {
  const canvas = document.getElementById('ef-canvas');
  const wrap   = document.getElementById('ef-chart-wrap');
  if (!canvas || !_efFrontier.length) return;

  const F          = _efFrontier;
  const maxSharpeP = F.reduce((b,p)=>p.sharpe>b.sharpe?p:b, F[0]);
  const minVarP    = F.reduce((b,p)=>p.sd<b.sd?p:b, F[0]);
  const maxRetP    = F.reduce((b,p)=>p.er>b.er?p:b, F[0]);
  const balP       = F[Math.floor(F.length*.50)];
  const named = [
    {p:minVarP,    label:'Min Variance',  col:'#1a7a45'},
    {p:F[Math.floor(F.length*.20)], label:'Conservative', col:'#2a6458'},
    {p:balP,       label:'Balanced',      col:'#2a4a7f'},
    {p:maxSharpeP, label:'★ Max Sharpe', col:'#2a4a7f'},
    {p:F[Math.floor(F.length*.78)], label:'Growth',       col:'#7c4a1e'},
    {p:maxRetP,    label:'Max Return',    col:'#8b2020'},
  ];

  const bar = document.getElementById('ef-hover-bar');

  canvas.onmousemove = e => {
    const rect = canvas.getBoundingClientRect();
    const pad  = {t:20,r:24,b:44,l:54};
    const cssW = wrap.clientWidth||700, cssH=wrap.clientHeight||460;
    const cw   = cssW-pad.l-pad.r, ch=cssH-pad.t-pad.b;
    const ax   = _efAxisParams(F);
    const toX  = v=>pad.l+(v-ax.sdMin)/(ax.sdMax-ax.sdMin)*cw;
    const toY  = v=>pad.t+(1-(v-ax.erMin)/(ax.erMax-ax.erMin))*ch;

    const mx=e.clientX-rect.left, my=e.clientY-rect.top;
    if(mx<pad.l||mx>pad.l+cw||my<pad.t||my>pad.t+ch){
      if(_efHoverIdx!==-1){ _efHoverIdx=-1; _drawEfficientFrontier(); }
      if(bar) bar.innerHTML='<div style="padding:8px 14px;font-size:10px;color:var(--text3);font-style:italic;">Hover the frontier curve to explore risk–return trade-offs</div>';
      return;
    }

    // Snap to nearest frontier point
    let best=0, bestD=Infinity;
    F.forEach((p,i)=>{
      const dx=toX(p.sd)-mx, dy=toY(p.er)-my, d=dx*dx+dy*dy;
      if(d<bestD){bestD=d;best=i;}
    });
    if(best===_efHoverIdx) return;
    _efHoverIdx=best;
    _drawEfficientFrontier();

    const p      = F[best];
    const isMS   = p===maxSharpeP;
    const zone   = named.find(n=>n.p===p) || (p.sd<balP.sd?{label:'Conservative Zone',col:'#2a6458'}:{label:'Aggressive Zone',col:'#7c4a1e'});
    const vsOpt  = _efOptPoint ? `<span style="color:${p.er>_efOptPoint.er?'var(--green2)':'var(--red2)'};">${p.er>_efOptPoint.er?'+':''}${(p.er-_efOptPoint.er).toFixed(2)}% vs Current</span>` : '';
    const vsEW   = _efEwPoint  ? `<span style="color:var(--text3);">${p.er>_efEwPoint.er?'+':''}${(p.er-_efEwPoint.er).toFixed(2)}% vs EW</span>` : '';

    // Weights
    const weights = Object.entries(p.wts||{})
      .filter(([,w])=>w>0.005).sort((a,b)=>b[1]-a[1]).slice(0,6)
      .map(([id,w])=>{
        const c=COUNTRIES.find(x=>x.bloomberg===id);
        const ret=(_efUniverse.find(x=>x.bloomberg===id)||{})[efModel]||0;
        const bar2W=Math.min(100,Math.round(w*100*4));
        const rc=ret>12?'var(--green2)':ret<4?'var(--red2)':'var(--text2)';
        return `<div style="display:flex;align-items:center;gap:6px;padding:2px 0;">
          <span style="font-size:15px;line-height:1;width:22px;">${flag(c?.name||'')}</span>
          <span style="font-size:10px;color:var(--text2);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c?.name||id}</span>
          <div style="width:60px;height:5px;background:var(--border);border-radius:3px;position:relative;">
            <div style="position:absolute;left:0;top:0;height:100%;width:${bar2W}%;background:${rc};border-radius:3px;"></div>
          </div>
          <span style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:${rc};font-weight:600;min-width:36px;text-align:right;">${(w*100).toFixed(1)}%</span>
        </div>`;
      }).join('');

    if(bar) bar.innerHTML = `
      <div style="display:grid;grid-template-columns:auto 1fr 1fr;gap:0;width:100%;">
        <div style="padding:10px 16px;border-right:1px solid var(--border);background:${zone.col}15;min-width:130px;">
          <div style="font-size:9px;font-weight:700;color:${zone.col};text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;">${zone.label}</div>
          <div style="font-size:18px;font-weight:700;font-family:'IBM Plex Mono',monospace;color:${p.er>12?'var(--green2)':p.er<4?'var(--red2)':'var(--text)'};">${p.er.toFixed(2)}%</div>
          <div style="font-size:10px;color:var(--text3);margin-top:2px;">Expected Return</div>
          <div style="margin-top:8px;display:flex;flex-direction:column;gap:3px;">
            <div style="display:flex;justify-content:space-between;gap:16px;">
              <span style="font-size:9px;color:var(--text3);">Risk σ</span>
              <span style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:var(--text2);">${p.sd.toFixed(2)}%</span>
            </div>
            <div style="display:flex;justify-content:space-between;gap:16px;">
              <span style="font-size:9px;color:var(--text3);">Sharpe</span>
              <span style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:${isMS?'var(--accent2)':'var(--text2)'};font-weight:${isMS?700:400};">${p.sharpe.toFixed(3)}${isMS?' ★':''}</span>
            </div>
            ${vsOpt?'<div style="font-size:9px;margin-top:2px;">'+vsOpt+'</div>':''}
            ${vsEW ?'<div style="font-size:9px;">'+vsEW+'</div>':''}
          </div>
        </div>
        <div style="padding:10px 14px;border-right:1px solid var(--border);">
          <div style="font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Portfolio Weights</div>
          ${weights||'<span style="font-size:10px;color:var(--text3);">–</span>'}
        </div>
        <div style="padding:10px 14px;">
          <div style="font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Benchmark Compare</div>
          ${_efEwPoint?'<div style="margin-bottom:8px;"><div style="font-size:8px;color:var(--text3);margin-bottom:2px;">vs Equal-Weight</div><div style="font-size:13px;font-family:\'IBM Plex Mono\',monospace;font-weight:700;color:'+(p.er>_efEwPoint.er?'var(--green2)':'var(--red2)')+';">'+(p.er>_efEwPoint.er?'+':'')+(p.er-_efEwPoint.er).toFixed(2)+'%</div><div style="font-size:9px;color:var(--text3);">EW Sharpe: '+_efEwPoint.sharpe.toFixed(3)+'</div></div>':''}
          ${_efOptPoint?'<div><div style="font-size:8px;color:var(--text3);margin-bottom:2px;">vs Current Portfolio</div><div style="font-size:13px;font-family:\'IBM Plex Mono\',monospace;font-weight:700;color:'+(p.er>_efOptPoint.er?'var(--green2)':'var(--red2)')+';">'+(p.er>_efOptPoint.er?'+':'')+(p.er-_efOptPoint.er).toFixed(2)+'%</div><div style="font-size:9px;color:var(--text3);">Current Sharpe: '+_efOptPoint.sharpe.toFixed(3)+'</div></div>':''}
        </div>
      </div>`;
  };

  canvas.onmouseleave = () => {
    _efHoverIdx = -1;
    _drawEfficientFrontier();
    if(bar) bar.innerHTML='<div style="padding:8px 14px;font-size:10px;color:var(--text3);font-style:italic;">Hover the frontier curve to explore risk–return trade-offs</div>';
  };
}



function renderKPIs() {
  const valid = COUNTRIES.filter(c=>c.pe&&c.classification!=='Aggregate'&&c.pe<100);
  const pes = valid.map(c=>c.pe).sort((a,b)=>a-b);
  const median = pes[Math.floor(pes.length/2)];
  const acwi = COUNTRIES.find(c=>c.name==='MSCI ACWI');
  const cheapest = [...valid].sort((a,b)=>(a.pe_z||0)-(b.pe_z||0))[0];
  const dearest = [...valid].sort((a,b)=>(b.pe_z||0)-(a.pe_z||0))[0];

  document.getElementById('kpi-row').innerHTML = `
    <div class="kpi blue">
      <div class="kpi-lbl">MSCI ACWI PE</div>
      <div class="kpi-val">${acwi?acwi.pe.toFixed(1):'–'}</div>
      <div class="kpi-sub">Fwd PE ${acwi?acwi.best_pe.toFixed(1):'–'} · P/B ${acwi?acwi.pb.toFixed(2):'–'} · Margin ${acwi&&acwi.prof_margin?acwi.prof_margin.toFixed(1)+'%':'–'}</div>
