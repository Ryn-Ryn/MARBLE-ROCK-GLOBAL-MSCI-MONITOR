function drawAllSparklines() {
  document.querySelectorAll('.prof-sparkline').forEach(cv => {
    const ticker = cv.dataset.ticker;
    const series = PRICE_DATA[ticker];
    if (!series || series.length < 10) return;
    const W = cv.parentElement.clientWidth || 195;
    const H = 28;
    cv.width = W; cv.height = H;
  cv.style.width = W+'px'; cv.style.height = H+'px';
    const ctx = cv.getContext('2d');
    // Last 2 years of data
    const cut = new Date(); cut.setFullYear(cut.getFullYear()-2);
    const cutStr = cut.toISOString().slice(0,10);
    const data = series.filter(r => r[0] >= cutStr);
    if (data.length < 5) return;
    const vals = data.map(r => r[1]);
    const mn = Math.min(...vals), mx = Math.max(...vals);
    const toX = i => (i / (data.length-1)) * W;
    const toY = v => H - 3 - ((v - mn) / (mx - mn || 1)) * (H - 6);
    const last = vals[vals.length-1], first = vals[0];
    const up = last >= first;
    const grad = ctx.createLinearGradient(0, 0, W, 0);
    grad.addColorStop(0, up ? 'rgba(29,92,58,0.3)' : 'rgba(139,32,32,0.3)');
    grad.addColorStop(1, up ? 'rgba(42,122,79,0.9)' : 'rgba(176,48,48,0.9)');
    ctx.beginPath();
    ctx.strokeStyle = grad;
    ctx.lineWidth = 1.5;
    data.forEach((r,i) => {
      const x = toX(i), y = toY(r[1]);
      i === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    });
    ctx.stroke();
    // End dot
    ctx.fillStyle = up ? 'var(--green2)' : 'var(--red2)';
    ctx.beginPath();
    ctx.arc(toX(data.length-1), toY(last), 2.5, 0, Math.PI*2);
    ctx.fill();
  });
}

