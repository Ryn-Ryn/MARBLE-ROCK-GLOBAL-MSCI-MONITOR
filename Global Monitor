// PROFILE GRID
// ══════════════════════════════════════════════════════════
let profFilterCls = 'all', profSearchStr = '', profTradeFilterVal = 'all';

function renderProfileGrid() {
  let d = COUNTRIES.filter(c => c.classification !== 'Aggregate');
  if (profFilterCls !== 'all') d = d.filter(c => c.classification === profFilterCls);
  if (profTradeFilterVal !== 'all') d = d.filter(c => { const p = COUNTRY_PROFILES[c.name]; return p && p.tradeStatus === profTradeFilterVal; });
  if (profSearchStr) d = d.filter(c => c.name.toLowerCase().includes(profSearchStr.toLowerCase()));

  document.getElementById('prof-grid').innerHTML = d.map(c => {
    const p = COUNTRY_PROFILES[c.name];
    const statusBadge = p ? {
      exporter:'<span style="font-size:9px;font-weight:700;font-family:\'IBM Plex Mono\',monospace;padding:1px 6px;border-radius:2px;background:rgba(29,92,58,.1);color:var(--green);border:1px solid rgba(29,92,58,.25);">NET EXPORTER</span>',
      importer:'<span style="font-size:9px;font-weight:700;font-family:\'IBM Plex Mono\',monospace;padding:1px 6px;border-radius:2px;background:rgba(139,32,32,.1);color:var(--red);border:1px solid rgba(139,32,32,.25);">NET IMPORTER</span>',
      balanced:'<span style="font-size:9px;font-weight:700;font-family:\'IBM Plex Mono\',monospace;padding:1px 6px;border-radius:2px;background:rgba(122,64,16,.1);color:var(--orange);border:1px solid rgba(122,64,16,.25);">BALANCED</span>'
    }[p.tradeStatus] : '';

    const topExp = p ? p.topExports.slice(0,2).map(e=>e.name).join(', ') : '—';
    const topImp = p ? p.topImports.slice(0,1).map(e=>e.name).join(', ') : '—';

    return `<div class="prof-card" onclick="openProfileDetail('${c.name}')" style="border-left-color:${clsColor(c.classification)};">
      <div class="prof-card-top">
        <div class="prof-card-flag">${flag(c.name)}</div>
        <div style="flex:1;min-width:0;">
          <div class="prof-card-name">${c.name}</div>
          <div class="prof-card-cls" style="color:${clsColor(c.classification)}">${c.classification} · ${c.region}</div>
        </div>
        ${statusBadge}
      </div>
      <div style="display:flex;gap:8px;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid var(--border);">
        <div style="flex:1;text-align:center;">
