function _renderZCharts() {
  const peData=_zData.map(d=>({d:d.d,y:d.v,m:d.m,s:d.s}));
  const pbData=_zDataPb.map(d=>({d:d.d,y:d.v,m:d.m,s:d.s}));
  const peOsc=_zData.map(d=>({d:d.d,y:d.z}));
  const pbOsc=_zDataPb.map(d=>({d:d.d,y:d.z}));
  const cmpPe=_zDataCmp.map(d=>({d:d.d,y:d.v}));
  const cmpPb=_zDataCmpPb.map(d=>({d:d.d,y:d.v}));
  const ci=_zCrosshairIdx>=0?_zCrosshairIdx:undefined;
  drawLineChart('z-main',peData,{bands:true,meanLine:true,dec:1,color:'#3d6baf',lw:1.8,crosshair:ci,overlay:cmpPe.length?{data:cmpPe,color:'#b08a2a'}:null});
