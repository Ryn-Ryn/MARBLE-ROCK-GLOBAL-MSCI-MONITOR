// TABLE — fix #2 (no implicit event), #3 (no nth-child), #6, #11, #18
// ══════════════════════════════════════════════════════════
let tblFilter='all', tblSortKey='pe_z_active', tblSortAsc=true, tblSearchStr='', tableZMode='universe';

function setTableZMode(mode, btn) {
  tableZMode = mode;
  document.querySelectorAll('#table-z-toggle .z-mode-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tbl-meta').textContent = mode==='universe'?'vs 15-country demo universe':'vs same classification peers';
  renderTable();
}

function renderTable() {
  const zField = field => tableZMode==='classification'
    ? (field==='pe'?'pe_z_cls':'pb_z_cls')
    : (field==='pe'?'pe_z':'pb_z');

  let rows = [...COUNTRIES];
  if(tblFilter!=='all') rows = rows.filter(c=>c.classification===tblFilter);
  if(tblSearchStr) rows = rows.filter(c=>c.name.toLowerCase().includes(tblSearchStr.toLowerCase()));

  // Resolve active z field for sorting
  const resolveSortKey = k => {
    if(k==='pe_z_active') return tableZMode==='classification'?'pe_z_cls':'pe_z';
    if(k==='pb_z_active') return tableZMode==='classification'?'pb_z_cls':'pb_z';
    return k;
  };
  const sk = resolveSortKey(tblSortKey);

  // Pinned aggregates: separate and sort rest
  const pinned = rows.filter(c=>c.classification==='Aggregate');
  const rest = rows.filter(c=>c.classification!=='Aggregate');
  rest.sort((a,b)=>{
    const av=a[sk], bv=b[sk];
    if(av==null&&bv==null) return 0;
    if(av==null) return 1; if(bv==null) return -1;
    if(typeof av==='string') return tblSortAsc?av.localeCompare(bv):bv.localeCompare(av);
    return tblSortAsc?av-bv:bv-av;
  });

  const toRender = tblFilter==='Aggregate'?pinned:[...rest,...(tblFilter==='all'?pinned:[])];

  document.getElementById('val-tbody').innerHTML = toRender.map(c=>{
    const peZKey = zField('pe'), pbZKey = zField('pb');
    const peZ = c[peZKey], pbZ = c[pbZKey];
    const isPinned = c.classification==='Aggregate';
    const peZBarW = peZ!=null?Math.min(100,Math.abs(peZ)/3*100):0;
    const pbZBarW = pbZ!=null?Math.min(100,Math.abs(pbZ)/3*100):0;
    const peBarPos = peZ!=null&&peZ<0?`right:50%;width:${peZBarW/2}%`:`left:50%;width:${peZBarW/2}%`;
    const pbBarPos = pbZ!=null&&pbZ<0?`right:50%;width:${pbZBarW/2}%`:`left:50%;width:${pbZBarW/2}%`;
    const disc = c.pe_discount;
    const discHtml = disc!=null?`<span class="disc-badge" style="background:${disc>0?'rgba(239,68,68,.12)':'rgba(16,185,129,.12)'};color:${disc>0?'var(--red2)':'var(--green2)'};">${disc>0?'+':''}${disc.toFixed(0)}%</span>`:'–';
    return `<tr class="${isPinned?'pinned':''}" style="cursor:pointer;" onclick="goToTab('screener');setTimeout(()=>openProfileDetail('${c.name}'),60);">
      <td><div class="ctry-cell"><span class="ctry-flag">${flag(c.name)}</span><span class="ctry-name">${c.name}</span></div></td>
      <td>${clsBadge(c.classification)}</td>
      <td class="mono" style="color:var(--text3)">${c.region}</td>
      <td class="mono">${fmtX(c.pe)}</td>
      <td><div class="z-cell">
        <span class="z-num" style="color:${zColor(peZ)}">${zLabel(peZ)}</span>
        <div class="z-pip"><div class="z-pip-fill" style="${peBarPos};background:${zColor(peZ)};opacity:.7"></div></div>
      </div></td>
      <td class="mono" style="color:var(--text3)">${fmtX(c.best_pe)}</td>
      <td>${discHtml}</td>
      <td class="mono">${fmtX(c.pb,2)}</td>
      <td><div class="z-cell">
        <span class="z-num" style="color:${zColor(pbZ)}">${zLabel(pbZ)}</span>
        <div class="z-pip"><div class="z-pip-fill" style="${pbBarPos};background:${zColor(pbZ)};opacity:.7"></div></div>
      </div></td>
      <td class="mono" style="color:var(--text3)">${fmtP(c.prof_margin)}</td>
      <td class="mono" style="font-size:10px;">${(()=>{
        const px=PRICE_DATA[c.bloomberg];
        if(!px||px.length<2) return '—';
        const lat=px[px.length-1], prv=px[px.length-2];
        const chg=((lat[1]-prv[1])/prv[1]*100);
        const col=chg>=0?'var(--green2)':'var(--red2)';
        const sign=chg>=0?'+':'';
        return '<span style="color:'+col+';">'+sign+chg.toFixed(1)+'%</span>';
      })()}</td>
    </tr>`;
  }).join('');
}

function filterTable(cls,btn) {
  tblFilter=cls;
  document.querySelectorAll('.tbl-ctrl .fb').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderTable();
}
function sortTable(key) {
  if(tblSortKey===key) tblSortAsc=!tblSortAsc; else{tblSortKey=key;tblSortAsc=true;}
  renderTable();
}
function tblSearch(v){tblSearchStr=v;renderTable();}

